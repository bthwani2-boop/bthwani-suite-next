node_modules/
.pnpm-store/

# Exclude plain-text and markdown files from Graphify semantic scan
**/*.txt
**/*.md
**/*.pdf
**/*.zip
**/*.png
**/*.jpg
**/*.jpeg
**/*.webp
**/*.gif
**/*.svg
**/*.ico


.env
.env.*
!.env.example
dist/
build/
.next/
.expo/
coverage/
*.tsbuildinfo
.DS_Store
Thumbs.db


graphify-out/

.nx/cache/
.nx/workspace-data/

# Local images only
*.png
*.jpg
*.jpeg
*.webp
*.gif
*.ico
!services/dsh/evidence/**/*.png
services/dsh/evidence/DSH-002-home-discovery-fullstack/screenshots/
services/dsh/database/seeds/local/media/

.gocache*/
.gomodcache*/
.cache/

# BTHWANI YAGNI / smallest-diff outputs
.yagni-out/

# Agent local state
.aider*
!.aiderignore

# Allow only bounded summaries/inventories/manifests inside .diagnostics
!.diagnostics/
.diagnostics/*
!.diagnostics/operational-journey-factory/
.diagnostics/operational-journey-factory/*
.diagnostics/operational-journey-factory/tool-evidence/
!.diagnostics/operational-journey-factory/inventories/
!.diagnostics/operational-journey-factory/inventories/*
!.diagnostics/operational-journey-factory/*.json
!.diagnostics/operational-journey-factory/*.md
!.diagnostics/operational-journey-factory/*.mjs
# Raw diagnostic outputs must never be tracked (reconciliation gate policy)
.diagnostics/operational-journey-factory/command-results.json
.diagnostics/operational-journey-factory/knip-current.json
tools/diagnostics/graph.json
tools/diagnostics/*.raw.json
tools/diagnostics/*.full.json
tools/diagnostics/knip-report.json
*.log
node-gates*.log
*_HANDOFF.zip
.claude/settings.local.json

# Generated Swagger / OpenAPI bundles
*.bundled.json

# Explicitly track bthwani-deep-diagnostic-input.md
!tools/diagnostics/bthwani-deep-diagnostic-input.md

# Explicitly track TOOLS_SETUP.md
!tools/diagnostics/TOOLS_SETUP.md

# Explicitly track operational journey factory governance templates
!governance/operational_journey_factory/
!governance/operational_journey_factory/**/*.md
!governance/operational_journey_factory/generated/
!governance/operational_journey_factory/generated/.gitkeep

# Explicitly track operational journey checklist
!tools/checklist/operational-journey-factory-checklist.md
!tools/checklist/**/
!tools/checklist/**/*.md

# Explicitly track diagnostic scripts
!tools/diagnostics/scripts/*.mjs

# Explicitly track bthwani prompts
!tools/prompts/
!tools/prompts/**/*.md

*.pem
*.key
*.p8
*.p12
*.jks
*.keystore
*credentials*.json
service-account*.json
secrets.local.*
passwords.local.*
credentials.local.*
