{
  "schemaVersion": 2,
  "policy": {
    "noAllGuardsByDefault": true,
    "noFullLintByDefault": true,
    "noZipByDefault": true,
    "guardsVerifyOnly": true,
    "ciSourceMutationForbidden": true,
    "sameCommitEvidenceRequired": true
  },
  "guardSets": {
    "foundation": [
      "governance-schema",
      "agent-governance",
      "guard-registry",
      "ui-kit-boundary",
      "runtime-config",
      "no-broken-imports",
      "cleanup-policy",
      "api-binding",
      "backend-api-binding"
    ],
    "journey": [
      "governance-schema",
      "agent-governance",
      "guard-registry",
      "fullstack-boundary",
      "wlt-financial-boundary",
      "runtime-config",
      "no-broken-imports",
      "api-binding",
      "backend-api-binding",
      "live-cross-journey-integrity"
    ],
    "governance": [
      "governance-schema",
      "agent-governance",
      "guard-registry"
    ]
  }
}
