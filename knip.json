{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    ".cache/**",
    ".gocache*/**",
    ".gomodcache*/**",
    "tools/registry/runs/**",
    "tools/diagnostics/**",
    "services/dsh/evidence/**",
    "infra/**",
    "governance/**",
    ".github/**"
  ],
  "ignoreDependencies": [
    "@react-native-async-storage/async-storage",
    "@react-native-community/netinfo",
    "@react-native/metro-config",
    "expo-file-system",
    "expo-haptics",
    "expo-image-picker",
    "expo-location",
    "expo-system-ui",
    "expo-updates",
    "react-native-gesture-handler",
    "react-native-maps",
    "react-native-reanimated",
    "react-native-screens",
    "react-native-svg",
    "react-native-worklets",
    "react-native-web",
    "@bthwani/app-shell",
    "@expo/vector-icons",
    "@types/react",
    "@ast-grep/cli",
    "@stoplight/spectral-cli",
    "autocannon",
    "babel-plugin-react-compiler",
    "dependency-cruiser",
    "markdownlint-cli2",
    "sherif",
    "size-limit"
  ],
  "ignoreBinaries": [
    "dev",
    "go",
    "pwsh",
    "graphify",
    "k6",
    "gitleaks"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "duplicates": "off"
  },
  "workspaces": {
    "apps/*/runtime": {
      "entry": [
        "src/App.tsx",
        "src/index.{ts,tsx}",
        "src/main.{ts,tsx}",
        "src/app/**/index.{ts,tsx}",
        "src/app/**/*Screen.{ts,tsx}"
      ]
    },
    "services/dsh": {
      "entry": [
        "frontend/app-*/index.{ts,tsx}",
        "frontend/app-*/**/*Surface.tsx",
        "frontend/app-*/**/*Screen.tsx",
        "frontend/app-*/**/*Panel.tsx",
        "frontend/app-*/**/*Sheet.tsx",
        "frontend/control-panel/**/*Screen.tsx",
        "frontend/control-panel/**/*Panel.tsx",
        "frontend/shared/**/index.{ts,tsx}",
        "frontend/shared/**/*.registry.ts",
        "frontend/shared/**/*.routes.ts",
        "frontend/shared/**/*.contract.ts",
        "frontend/shared/**/*.policy.ts",
        "frontend/shared/**/*.view-model.ts",
        "frontend/shared/**/*.adapter.ts",
        "frontend/shared/**/*.transport.ts",
        "frontend/shared/**/*.state-machine.ts",
        "frontend/shared/**/*.states.ts",
        "frontend/shared/**/*.types.ts",
        "frontend/shared/**/*.model.ts",
        "frontend/shared/**/*.api.ts",
        "frontend/shared/**/*.client.ts",
        "frontend/shared/**/*.map.ts"
      ]
    },
    "services/wlt": {
      "entry": [
        "frontend/shared/**/*.ts"
      ]
    },
    "shared/ui-kit": {
      "entry": [
        "src/**/*.{ts,tsx}"
      ]
    },
    "core/identity": {
      "entry": ["clients/index.ts", "clients/index.js", "clients/use-identity-session.js"]
    },
    "core/platform-control": {
      "entry": ["service.manifest.ts"]
    },
    "core/providers": {
      "entry": ["service.manifest.ts"]
    },
    "core/workforce": {
      "entry": ["service.manifest.ts"]
    }
  }
}
