{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "apps/*/runtime/src/App.tsx",
    "apps/*/runtime/src/index.{ts,tsx}",
    "apps/*/runtime/src/main.{ts,tsx}",
    "services/dsh/frontend/app-*/index.{ts,tsx}",
    "services/dsh/frontend/app-*/**/*Surface.tsx",
    "services/dsh/frontend/app-*/**/*Screen.tsx",
    "services/dsh/frontend/app-*/**/*Panel.tsx",
    "services/dsh/frontend/app-*/**/*Sheet.tsx",
    "services/dsh/frontend/control-panel/**/*Screen.tsx",
    "services/dsh/frontend/control-panel/**/*Panel.tsx",
    "services/dsh/frontend/shared/**/index.{ts,tsx}",
    "services/dsh/frontend/shared/**/*.registry.ts",
    "services/dsh/frontend/shared/**/*.routes.ts",
    "services/dsh/frontend/shared/**/*.contract.ts",
    "services/dsh/frontend/shared/**/*.policy.ts",
    "services/dsh/frontend/shared/**/*.view-model.ts",
    "services/dsh/frontend/shared/**/*.adapter.ts",
    "services/dsh/frontend/shared/**/*.transport.ts",
    "services/dsh/frontend/shared/**/*.state-machine.ts",
    "services/dsh/frontend/shared/**/*.states.ts",
    "services/dsh/frontend/shared/**/*.types.ts",
    "services/dsh/frontend/shared/**/*.model.ts",
    "services/dsh/frontend/shared/**/*.api.ts",
    "services/dsh/frontend/shared/**/*.client.ts",
    "services/dsh/frontend/shared/**/*.map.ts",
    "services/wlt/frontend/shared/**/*.ts",
    "shared/ui-kit/src/**/*.{ts,tsx}",
    "apps/control-panel/runtime/src/**/*.{ts,tsx}"
  ],
  "ignore": [
    "node_modules/**",
    ".pnpm-store/**",
    ".next/**",
    ".expo/**",
    "dist/**",
    "build/**",
    "coverage/**",
    "graphify-out/**",
    ".yagni-out/**",
    ".nx/**",
    ".cache/**",
    ".gocache*/**",
    ".gomodcache*/**",
    "tools/registry/runs/**",
    "tools/diagnostics/**",
    "services/dsh/evidence/**",
    "infra/**",
    "governance/**",
    ".github/**"
  ],
  "ignoreFiles": [
    "**/*.generated.ts",
    "**/*.generated.tsx",
    "**/*.gen.ts",
    "**/__generated__/**"
  ],
  "ignoreDependencies": [
    "@react-native-async-storage/async-storage",
    "@react-native-community/netinfo",
    "@react-native/metro-config",
    "expo-file-system",
    "expo-haptics",
    "expo-image-picker",
    "expo-location",
    "expo-system-ui",
    "expo-updates",
    "react-native-gesture-handler",
    "react-native-maps",
    "react-native-reanimated",
    "react-native-screens",
    "react-native-svg",
    "react-native-worklets",
    "react-native-web",
    "@bthwani/app-shell",
    "@bthwani/core-identity",
    "@expo/vector-icons",
    "@types/react",
    "@ast-grep/cli",
    "@stoplight/spectral-cli",
    "autocannon",
    "babel-plugin-react-compiler",
    "dependency-cruiser",
    "jscpd",
    "madge",
    "markdownlint-cli2",
    "sherif",
    "size-limit"
  ],
  "ignoreExportsUsedInFile": true
}
