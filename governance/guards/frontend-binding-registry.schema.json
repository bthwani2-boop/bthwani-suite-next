{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BThwani Frontend Static Binding Registry",
  "type": "object",
  "required": ["schemaVersion", "evidenceScope", "entries"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "evidenceScope": { "const": "STATIC_BINDING" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "surface", "screen", "controller", "operationId", "route", "capabilityId"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9.-]+$" },
          "surface": { "enum": ["app-client", "app-partner", "app-captain", "app-field", "control-panel"] },
          "screen": { "type": "string", "minLength": 1 },
          "controller": { "type": "string", "minLength": 1 },
          "operationId": { "type": "string", "minLength": 1 },
          "route": { "type": "string", "pattern": "^(GET|POST|PUT|PATCH|DELETE) /" },
          "capabilityId": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
