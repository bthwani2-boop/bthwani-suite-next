{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BthwaniGuardSchema",
  "description": "Schema for verifying guard definitions in guard-registry.json",
  "type": "object",
  "required": ["entries"],
  "additionalProperties": false,
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "script", "exit_level", "description"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "name": {
            "type": "string"
          },
          "script": {
            "type": "string",
            "pattern": "^guard:[a-z0-9-]+$"
          },
          "exit_level": {
            "type": "string",
            "enum": ["fail", "warn"]
          },
          "description": {
            "type": "string"
          },
          "source_file": {
            "type": "string"
          }
        }
      }
    }
  }
}
