{
  "schemaVersion": 2,
  "entries": [
    {
      "guardId": "governance-schema",
      "assuranceClass": "SCHEMA_INTEGRITY",
      "proves": ["Registered governance JSON conforms to its schema", "Selected cross-registry invariants are consistent"],
      "doesNotProve": ["Runtime behavior", "Human approval", "Branch protection", "Final closure"],
      "closureEligible": false
    },
    {
      "guardId": "agent-governance",
      "assuranceClass": "POLICY_ALIGNMENT",
      "proves": ["Active and conditional skills are governed", "Legacy skills are retired", "Agent roles, skill dependencies, routing, and SDLC authorities align"],
      "doesNotProve": ["Real subagent availability", "Human independence", "Execution quality", "Final closure"],
      "closureEligible": false
    },
    {
      "guardId": "authority-separation",
      "assuranceClass": "POLICY_ALIGNMENT",
      "proves": ["Required logical authorities are registered", "The master supervisor is advisory-only", "Governance and CI use separate active skills and owners", "G4 and later SDLC stage ownership is ordered"],
      "doesNotProve": ["Real people or teams exist", "GitHub approvals are independent", "A stage passed", "Final closure"],
      "closureEligible": false
    },
    {
      "guardId": "saas-governance",
      "assuranceClass": "SCHEMA_INTEGRITY",
      "proves": ["The SaaS governance state validates against its schema", "Readiness states are separated from canonical decisions", "Deferred commercial activation and required evidence boundaries are internally consistent"],
      "doesNotProve": ["Platform-wide tenant isolation", "Cross-tenant runtime tests", "WLT tenant financial isolation", "Commercial SaaS readiness or activation"],
      "closureEligible": false,
      "requiredFollowUpForRuntimeClaim": ["Same-commit tenant-context propagation evidence", "Cross-tenant negative runtime tests", "Independent isolation-security and financial-control approval"]
    },
    {
      "guardId": "guard-registry",
      "assuranceClass": "POLICY_ALIGNMENT",
      "proves": ["Guards, package scripts, runners, workflows, permissions, immutable action references, and required workflow topology align"],
      "doesNotProve": ["Workflow execution success", "Branch ruleset enforcement", "Runtime behavior", "Final closure"],
      "closureEligible": false
    },
    {
      "guardId": "sdlc",
      "assuranceClass": "LIFECYCLE_INTEGRITY",
      "proves": ["SDLC schemas and lifecycle rules are structurally valid", "Provided artifacts obey same-commit, impact, and approval rules"],
      "doesNotProve": ["A stage passed without an artifact", "Missing human approvals", "Runtime behavior", "Final closure"],
      "closureEligible": false
    },
    {
      "guardId": "go-routes-ci",
      "assuranceClass": "STATIC_AST",
      "proves": ["Supported Go router registrations can be extracted from source AST"],
      "doesNotProve": ["Endpoint reachability", "Authentication correctness", "Database effects", "Runtime success"],
      "closureEligible": false,
      "requiredFollowUpForRuntimeClaim": ["Same-commit service startup", "HTTP request and response evidence"]
    },
    {
      "guardId": "frontend-feature-binding",
      "assuranceClass": "STATIC_BINDING",
      "proves": ["Declared screen reaches its controller through static imports or exports", "Declared OpenAPI operation, Go route, and service capability exist"],
      "doesNotProve": ["Screen navigation reachability", "Successful network execution", "Correct response state", "Runtime or visual closure"],
      "closureEligible": false,
      "requiredFollowUpForRuntimeClaim": ["Same-commit application runtime", "Actor-specific journey smoke", "Failure and permission evidence"]
    },
    {
      "guardId": "logic-coverage",
      "assuranceClass": "STATIC_HEURISTIC",
      "proves": ["Selected dead-action and local-stub anti-patterns are absent"],
      "doesNotProve": ["Every action is behaviorally correct", "Mutation persistence", "Cross-surface consistency", "Runtime success"],
      "closureEligible": false,
      "requiredFollowUpForRuntimeClaim": ["Interaction tests", "State readback", "Negative-path evidence"]
    },
    {
      "guardId": "runtime-real-bindings",
      "assuranceClass": "STATIC_ANTI_STUB",
      "proves": ["Selected runtime-facing source paths do not contain forbidden local success, placeholder transport, or fake commercial truth markers"],
      "doesNotProve": ["A runtime is running", "Backend reachability", "Provider behavior", "Journey completion"],
      "closureEligible": false,
      "requiredFollowUpForRuntimeClaim": ["Same-commit runtime smoke", "Backend and database readback"]
    },
    {
      "guardId": "live-cross-journey-integrity",
      "assuranceClass": "SCOPED_REGRESSION",
      "proves": ["Named identity, authorization, BFF, checkout, captain, WLT posture, and CI regression invariants remain present or absent as declared"],
      "doesNotProve": ["Complete cross-journey coverage", "All services and surfaces", "Runtime success", "Production readiness"],
      "closureEligible": false,
      "requiredFollowUpForRuntimeClaim": ["Journey-specific integration tests", "Same-commit multi-surface runtime evidence"]
    },
    {
      "guardId": "performance-budget",
      "assuranceClass": "CONFIGURATION_BUDGET",
      "proves": ["Performance budget configuration exists and is internally valid"],
      "doesNotProve": ["Measured latency", "Throughput", "Memory stability", "Noisy-neighbor behavior"],
      "closureEligible": false,
      "requiredFollowUpForRuntimeClaim": ["Versioned benchmark result", "Environment and workload metadata"]
    },
    {
      "guardId": "a11y",
      "assuranceClass": "STATIC_HEURISTIC",
      "proves": ["Selected static accessibility contracts are present"],
      "doesNotProve": ["Runtime accessibility tree", "Keyboard behavior", "Screen-reader usability", "Visual acceptance"],
      "closureEligible": false,
      "requiredFollowUpForRuntimeClaim": ["Runtime accessibility checks", "Manual assistive-technology review when required"]
    },
    {
      "guardId": "a11y-runtime",
      "assuranceClass": "RUNTIME_ACCESSIBILITY",
      "proves": ["The configured Playwright and axe checks executed against the declared runtime target and passed"],
      "doesNotProve": ["Complete screen-reader usability", "All native mobile surfaces", "Manual accessibility acceptance", "Final closure"],
      "closureEligible": false,
      "requiredFollowUpForRuntimeClaim": ["Runtime target identity", "Manual assistive-technology review when required"]
    },
    {
      "guardId": "workflow-lint",
      "assuranceClass": "SYNTAX_VALIDATION",
      "proves": ["Workflow syntax satisfies actionlint"],
      "doesNotProve": ["Workflow security", "Job success", "Required-check enforcement", "Final closure"],
      "closureEligible": false
    },
    {
      "guardId": "workflow-security",
      "assuranceClass": "STATIC_SECURITY_AUDIT",
      "proves": ["Configured high-confidence high-severity workflow findings are absent"],
      "doesNotProve": ["All workflow vulnerabilities are absent", "External action integrity beyond pinned commit", "Job success", "Repository ruleset enforcement"],
      "closureEligible": false
    },
    {
      "guardId": "actions-pin",
      "assuranceClass": "IMMUTABLE_REFERENCE",
      "proves": ["Configured external GitHub Action references are pinned to immutable commit SHAs"],
      "doesNotProve": ["The pinned code is trustworthy", "Workflow job success", "Required-check enforcement", "Final closure"],
      "closureEligible": false
    }
  ]
}
