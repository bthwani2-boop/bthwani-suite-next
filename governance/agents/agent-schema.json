{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BthwaniAgentRegistrySchema",
  "type": "object",
  "required": ["schemaVersion", "entries"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 2 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "kind",
          "owner",
          "scope",
          "description",
          "capability_tier",
          "authority_domains",
          "allowed_modes",
          "may_final_approve_own_work",
          "primary_file"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string", "minLength": 1 },
          "kind": { "enum": ["adapter", "logical_role", "supervisor"] },
          "owner": { "type": "string", "minLength": 1 },
          "scope": { "enum": ["global", "project", "service", "shared", "tools", "infra", "product", "quality", "security", "release"] },
          "description": { "type": "string", "minLength": 1 },
          "capability_tier": { "enum": ["T0_MINIMAL", "T1_BALANCED", "T2_SPECIALIST", "T3_ADVISORY_MAX"] },
          "authority_domains": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
          },
          "approval_domains": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
          },
          "allowed_modes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": ["read", "plan", "write", "verify", "approve", "release"]
            }
          },
          "may_final_approve_own_work": { "type": "boolean" },
          "requires_independent_review": { "type": "boolean" },
          "primary_file": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
