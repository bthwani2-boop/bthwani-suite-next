{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BThwani SDLC Change Impact",
  "type": "object",
  "required": ["schemaVersion", "capabilityId", "taskMode", "repositoryMode", "branch", "baseCommitSha", "affectedPaths", "riskClass", "productImpact", "impacts"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 3 },
    "capabilityId": { "type": "string", "minLength": 1 },
    "taskMode": { "enum": ["analysis_only", "implementation_or_closure", "merge_review"] },
    "repositoryMode": { "enum": ["REMOTE_ONLY", "LOCAL"] },
    "branch": { "type": "string", "minLength": 1 },
    "baseCommitSha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "affectedPaths": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "riskClass": { "enum": ["low", "medium", "high", "critical"] },
    "productImpact": { "enum": ["NONE", "CHANGED", "UNKNOWN"] },
    "productTruthContract": { "type": "string", "pattern": "^governance/product/contracts/.+\\.product-truth\\.json$" },
    "productImpactReason": { "type": "string", "minLength": 1 },
    "impacts": {
      "type": "object",
      "required": ["backend", "frontend", "apiContract", "database", "visual", "qa", "security", "runtime", "wltFinance", "tenant", "governance", "ci", "release", "production"],
      "additionalProperties": false,
      "properties": {
        "backend": { "type": "boolean" },
        "frontend": { "type": "boolean" },
        "apiContract": { "type": "boolean" },
        "database": { "type": "boolean" },
        "visual": { "type": "boolean" },
        "qa": { "type": "boolean" },
        "security": { "type": "boolean" },
        "runtime": { "type": "boolean" },
        "wltFinance": { "type": "boolean" },
        "tenant": { "type": "boolean" },
        "governance": { "type": "boolean" },
        "ci": { "type": "boolean" },
        "release": { "type": "boolean" },
        "production": { "type": "boolean" }
      }
    }
  },
  "allOf": [
    {"if":{"properties":{"productImpact":{"const":"CHANGED"}}},"then":{"required":["productTruthContract"]}},
    {"if":{"properties":{"productImpact":{"enum":["NONE","UNKNOWN"]}}},"then":{"required":["productImpactReason"]}},
    {"if":{"properties":{"impacts":{"properties":{"production":{"const":true}}}}},"then":{"properties":{"impacts":{"properties":{"release":{"const":true},"runtime":{"const":true}}}}}},
    {"if":{"properties":{"impacts":{"properties":{"release":{"const":true}}}}},"then":{"properties":{"impacts":{"properties":{"qa":{"const":true},"security":{"const":true}}}}}}
  ]
}
