{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BthwaniSkillSchema",
  "description": "Schema for verifying skill definitions in skills-registry.json",
  "type": "object",
  "required": ["entries"],
  "additionalProperties": false,
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "path", "owner", "scope", "evidence_required"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          },
          "evidence_required": {
            "type": "boolean"
          },
          "evidence_path_pattern": {
            "type": "string"
          }
        }
      }
    }
  }
}
