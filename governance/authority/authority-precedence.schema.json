{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BThwaniAuthorityPrecedence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "rootAuthority", "precedence", "documents"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "rootAuthority": { "type": "string", "minLength": 1 },
    "precedence": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rank", "id", "description"],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "id": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
          "description": { "type": "string", "minLength": 1 }
        }
      }
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "classification", "precedenceId", "authorityDomains"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "classification": {
            "enum": [
              "ROOT_AUTHORITY",
              "ACTIVE_CANONICAL",
              "CONDITIONAL_CANONICAL",
              "OWNER_CONTRACT",
              "ADAPTER",
              "DERIVED_SUPPORT",
              "HISTORICAL_REFERENCE"
            ]
          },
          "precedenceId": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
          "authorityDomains": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "appliesWhen": { "type": "string", "minLength": 1 },
          "scopeLimit": { "type": "string", "minLength": 1 },
          "supersedesStatusClaims": { "type": "boolean" }
        },
        "allOf": [
          {
            "if": { "properties": { "classification": { "const": "CONDITIONAL_CANONICAL" } } },
            "then": { "required": ["appliesWhen"] }
          }
        ]
      }
    }
  }
}
