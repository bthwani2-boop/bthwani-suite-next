    {
      "rank": 2,
      "id": "AUTHORITY_PRECEDENCE_REGISTRY",
      "description": "This registry is the single repository source for resolving governance authority conflicts."
    },
    {
      "rank": 3,
      "id": "AGENT_EXECUTION_POLICY",
      "description": "AGENTS.md governs repository-agent execution behavior without overriding domain ownership or formal stage approvals."
    },
    {
      "rank": 4,
      "id": "ACTIVE_CANONICAL_GOVERNANCE",
      "description": "Active canonical governance owns durable repository, service, security, evidence, product, and SDLC rules."
    },
    {
      "rank": 5,
      "id": "CONDITIONAL_CANONICAL_ANNEX",
      "description": "Conditional annexes apply only when their declared applicability condition is true."
    },
    {
      "rank": 6,
      "id": "MACHINE_READABLE_CONTRACT",
      "description": "Schemas, registries, manifests, and contract files encode active governance for automated validation."
    },
    {
      "rank": 7,
      "id": "OWNER_SKILL_CONTRACT",
      "description": "A skill may govern only its declared owner scope and may not override higher authority."
    },
    {
      "rank": 8,
      "id": "TOOL_ADAPTER",
      "description": "Adapters translate higher policy to a tool and may not add conflicting policy."
    },
    {
      "rank": 9,
      "id": "DERIVED_SUPPORT_ARTIFACT",
      "description": "Derived templates and support artifacts assist execution but never override their source authority."
    },
    {
      "rank": 10,
      "id": "HISTORICAL_REFERENCE",
      "description": "Historical phase records and extraction ledgers are evidence only; live manifests, contracts, and code own current state."
    }
  ],
