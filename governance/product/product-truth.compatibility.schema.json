{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BThwaniVersionedProductTruthCompatibility",
  "description": "Compatibility schema for pre-canonical journey product-truth records. Canonical numeric schemaVersion 1 records remain governed exclusively by product-truth.schema.json.",
  "type": "object",
  "required": ["journeyId", "negativeInvariants"],
  "properties": {
    "schemaVersion": {
      "oneOf": [
        { "type": "integer", "minimum": 2 },
        { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+){0,2}$" }
      ]
    },
    "journeyId": {
      "type": "string",
      "pattern": "^JRN-[0-9]{3}$"
    },
    "title": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "minLength": 1 },
    "actors": {
      "type": "array",
      "minItems": 1
    },
    "requiredSurfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "surfaces": {
      "type": "array",
      "minItems": 1
    },
    "negativeInvariants": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "technicalAcceptanceConditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "problem": {},
    "purpose": {},
    "operationalProblem": {},
    "goal": {},
    "targetOutcome": {},
    "capabilities": {
      "type": "array",
      "minItems": 1
    }
  },
  "allOf": [
    {
      "anyOf": [
        { "required": ["problem"] },
        { "required": ["purpose"] },
        { "required": ["operationalProblem"] },
        { "required": ["goal"] },
        { "required": ["targetOutcome"] },
        { "required": ["capabilities"] }
      ]
    },
    {
      "anyOf": [
        { "required": ["acceptanceCriteria"] },
        { "required": ["technicalAcceptanceConditions"] }
      ]
    },
    {
      "anyOf": [
        { "required": ["requiredSurfaces"] },
        { "required": ["surfaces"] }
      ]
    }
  ],
  "additionalProperties": true
}
