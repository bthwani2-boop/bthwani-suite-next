{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BThwaniVersionedProductTruthCompatibility",
  "description": "Compatibility schema for pre-canonical journey product-truth records. Canonical schemaVersion 1 records remain governed by product-truth.schema.json.",
  "type": "object",
  "required": ["journeyId", "status", "actors", "requiredSurfaces", "negativeInvariants"],
  "properties": {
    "schemaVersion": {
      "oneOf": [
        { "type": "integer", "minimum": 2 },
        { "type": "string", "minLength": 1 }
      ]
    },
    "journeyId": {
      "type": "string",
      "pattern": "^JRN-[0-9]{3}$"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "actors": {
      "type": "array",
      "minItems": 1
    },
    "requiredSurfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "negativeInvariants": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "technicalAcceptanceConditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "problem": { "type": "string", "minLength": 1 },
    "operationalProblem": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "targetOutcome": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "allOf": [
    {
      "anyOf": [
        { "required": ["problem"] },
        { "required": ["operationalProblem"] },
        { "required": ["capabilities"] }
      ]
    },
    {
      "anyOf": [
        { "required": ["acceptanceCriteria"] },
        { "required": ["technicalAcceptanceConditions"] }
      ]
    }
  ],
  "additionalProperties": true
}
