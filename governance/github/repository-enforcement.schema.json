{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BThwani GitHub Repository Enforcement Evidence",
  "type": "object",
  "required": [
    "schemaVersion",
    "repository",
    "targetBranch",
    "observedAt",
    "observed",
    "requiredCheckNames",
    "requiredPullRequestPolicy",
    "claims",
    "requiredRemediation",
    "decision"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 4 },
    "repository": { "const": "bthwani2-boop/bthwani-suite-next" },
    "targetBranch": { "const": "lian" },
    "observedAt": { "type": "string", "format": "date-time" },
    "observed": {
      "type": "object",
      "required": [
        "authenticatedUser",
        "organizationMembershipCount",
        "codeowners",
        "codeownersMode",
        "branchProtectionState",
        "requiredChecksState",
        "independentReviewerIdentityState",
        "sameCommitWorkflowRunsState"
      ],
      "additionalProperties": false,
      "properties": {
        "authenticatedUser": { "type": "string", "minLength": 1 },
        "organizationMembershipCount": { "type": "integer", "minimum": 0 },
        "codeowners": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[A-Za-z0-9-]+$" }
        },
        "codeownersMode": { "enum": ["SINGLE_OWNER_ROUTING", "MULTI_OWNER_ROUTING"] },
        "branchProtectionState": { "enum": ["PROVEN", "NOT_PROVEN"] },
        "requiredChecksState": { "enum": ["PROVEN", "NOT_PROVEN"] },
        "independentReviewerIdentityState": { "enum": ["PROVEN", "NOT_PROVEN"] },
        "sameCommitWorkflowRunsState": { "enum": ["PROVEN_PASS", "PROVEN_FAIL", "NOT_PROVEN"] }
      }
    },
    "requiredCheckNames": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "requiredPullRequestPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiredApprovingReviewCount",
        "dismissStaleApprovals",
        "requireCodeOwnerReview",
        "requireConversationResolution",
        "requireLastPushApprovalByDifferentActor",
        "allowForcePushes",
        "allowDeletions",
        "requireLinearHistory"
      ],
      "properties": {
        "requiredApprovingReviewCount": { "type": "integer", "minimum": 1 },
        "dismissStaleApprovals": { "const": true },
        "requireCodeOwnerReview": { "const": true },
        "requireConversationResolution": { "const": true },
        "requireLastPushApprovalByDifferentActor": { "const": true },
        "allowForcePushes": { "const": false },
        "allowDeletions": { "const": false },
        "requireLinearHistory": { "type": "boolean" }
      }
    },
    "claims": {
      "type": "object",
      "required": [
        "routingConfigured",
        "requiredCheckNamesDefined",
        "finalGateIncludesRuntime",
        "finalGateIncludesSurfaceActionInventory",
        "finalGateIncludesPrivacyIntegration",
        "separationOfDutiesProven",
        "sameCommitCiProven",
        "highRiskClosureAllowed"
      ],
      "additionalProperties": false,
      "properties": {
        "routingConfigured": { "type": "boolean" },
        "requiredCheckNamesDefined": { "type": "boolean" },
        "finalGateIncludesRuntime": { "type": "boolean" },
        "finalGateIncludesSurfaceActionInventory": { "type": "boolean" },
        "finalGateIncludesPrivacyIntegration": { "type": "boolean" },
        "separationOfDutiesProven": { "type": "boolean" },
        "sameCommitCiProven": { "type": "boolean" },
        "highRiskClosureAllowed": { "type": "boolean" }
      }
    },
    "requiredRemediation": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "decision": { "enum": ["PASS", "NEEDS_EVIDENCE", "FIX_REQUIRED", "BLOCKED_EXTERNAL"] }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "observed": { "properties": { "codeownersMode": { "const": "SINGLE_OWNER_ROUTING" } } }
        }
      },
      "then": {
        "properties": {
          "claims": {
            "properties": {
              "separationOfDutiesProven": { "const": false },
              "highRiskClosureAllowed": { "const": false }
            }
          },
          "decision": { "const": "NEEDS_EVIDENCE" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "observed": {
            "properties": {
              "sameCommitWorkflowRunsState": { "not": { "const": "PROVEN_PASS" } }
            }
          }
        }
      },
      "then": {
        "properties": {
          "claims": {
            "properties": {
              "sameCommitCiProven": { "const": false },
              "highRiskClosureAllowed": { "const": false }
            }
          },
          "decision": { "enum": ["NEEDS_EVIDENCE", "FIX_REQUIRED", "BLOCKED_EXTERNAL"] }
        }
      }
    },
    {
      "if": {
        "anyOf": [
          { "properties": { "observed": { "properties": { "branchProtectionState": { "const": "NOT_PROVEN" } } } } },
          { "properties": { "observed": { "properties": { "requiredChecksState": { "const": "NOT_PROVEN" } } } } },
          { "properties": { "observed": { "properties": { "independentReviewerIdentityState": { "const": "NOT_PROVEN" } } } } }
        ]
      },
      "then": {
        "properties": {
          "claims": { "properties": { "highRiskClosureAllowed": { "const": false } } },
          "decision": { "enum": ["NEEDS_EVIDENCE", "FIX_REQUIRED", "BLOCKED_EXTERNAL"] }
        }
      }
    }
  ]
}
