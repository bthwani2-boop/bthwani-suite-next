{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BThwaniDecisionVocabulary",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "canonicalDecisions", "aliases", "closureRules"],
  "properties": {
    "schemaVersion": { "const": 3 },
    "canonicalDecisions": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "class", "terminal", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
          "class": { "enum": ["pass", "fail", "blocked", "pending", "excluded", "closed"] },
          "terminal": { "type": "boolean" },
          "description": { "type": "string", "minLength": 1 },
          "scopePolicy": { "enum": ["DECLARED_SCOPE", "ALL_APPLICABLE"] },
          "requiredEvidenceScopes": {
            "type": "array",
            "uniqueItems": true,
            "items": { "$ref": "#/definitions/evidenceScope" }
          }
        }
      }
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["alias", "canonical", "evidenceScope"],
        "properties": {
          "alias": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
          "canonical": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
          "evidenceScope": {
            "anyOf": [
              { "const": "none" },
              { "$ref": "#/definitions/evidenceScope" }
            ]
          },
          "deprecated": { "type": "boolean" },
          "description": { "type": "string" }
        }
      }
    },
    "closureRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["closedDecision", "scopePolicy", "baseRequiredScopes", "conditionalRequiredScopes", "forbiddenOpenClasses"],
      "properties": {
        "closedDecision": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
        "scopePolicy": { "const": "ALL_APPLICABLE" },
        "baseRequiredScopes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/definitions/evidenceScope" }
        },
        "conditionalRequiredScopes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/definitions/evidenceScope" }
        },
        "forbiddenOpenClasses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["fail", "blocked", "pending"] }
        }
      }
    }
  },
  "definitions": {
    "evidenceScope": {
      "enum": ["static", "product", "runtime", "visual", "qa", "security", "finance", "isolation", "governance", "ci", "release", "production"]
    }
  }
}
