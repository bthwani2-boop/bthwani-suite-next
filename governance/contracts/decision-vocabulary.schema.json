{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BThwaniDecisionVocabulary",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "canonicalDecisions", "aliases", "closureRules"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "canonicalDecisions": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "class", "terminal", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
          "class": { "enum": ["pass", "fail", "blocked", "pending", "excluded", "closed"] },
          "terminal": { "type": "boolean" },
          "description": { "type": "string", "minLength": 1 },
          "requiredEvidenceScopes": {
            "type": "array",
            "uniqueItems": true,
            "items": { "enum": ["static", "runtime", "visual", "qa", "security", "release", "production"] }
          }
        }
      }
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["alias", "canonical", "evidenceScope"],
        "properties": {
          "alias": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
          "canonical": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
          "evidenceScope": { "enum": ["none", "static", "runtime", "visual", "qa", "security", "release", "production"] },
          "deprecated": { "type": "boolean" },
          "description": { "type": "string" }
        }
      }
    },
    "closureRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["closedDecision", "requiredScopes", "forbiddenOpenClasses"],
      "properties": {
        "closedDecision": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
        "requiredScopes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["static", "runtime", "visual", "qa", "security", "release", "production"] }
        },
        "forbiddenOpenClasses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["fail", "blocked", "pending"] }
        }
      }
    }
  }
}
