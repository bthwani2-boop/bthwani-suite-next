# Identity Runtime Environment — reserved, not active

IDENTITY_RUNTIME_STATE=RESERVED_NOT_ACTIVE
IDENTITY_CONTAINER_NAME=bthwani-identity-api-runtime
IDENTITY_HOST_PORT=58082
IDENTITY_INTERNAL_PORT=8082
IDENTITY_DATABASE_URL=postgres://identity_runtime:identity_runtime_password@postgres:5432/identity_runtime?sslmode=disable

# IDENTITY_LOCAL_BOOTSTRAP=true / IDENTITY_LOCAL_BOOTSTRAP_PASSWORD=<6+ chars>
# enable the local actor bootstrap. The password must be at least 6
# characters to match the OpenAPI LoginRequest.password contract; the
# backend refuses to start (log.Fatal) if it is shorter.

# Activation gate:
# core identity backend Dockerfile + /health + /ready + auth/session smoke
