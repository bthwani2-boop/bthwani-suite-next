# Control Panel Runtime Environment — reserved, not active

CONTROL_PANEL_RUNTIME_STATE=RESERVED_NOT_ACTIVE
CONTROL_PANEL_CONTAINER_NAME=bthwani-control-panel-runtime
CONTROL_PANEL_HOST_PORT=13000
CONTROL_PANEL_INTERNAL_PORT=3000

# Server-only (never exposed to the browser): used by the control-panel's
# Next.js BFF route handlers under src/app/api/auth/* and src/app/api/dsh/*
# to reach Identity and DSH on the user's behalf. The browser never talks to
# these backends directly and never sees a bearer token.
IDENTITY_API_BASE_URL=http://identity-api:8082
DSH_API_BASE_URL=http://dsh-api:8080

# Browser-visible: routes all DSH data-fetching through the same-origin BFF
# proxy instead of a cross-origin bearer-token call. Keep this relative.
NEXT_PUBLIC_DSH_API_BASE_URL=/api/dsh

# Activation gate:
# control-panel Dockerfile + BFF route smoke (/api/auth/session 401 when
# signed out) + full runtime:full:smoke walkthrough of every /dsh/* section
