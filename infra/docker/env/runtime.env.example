COMPOSE_PROJECT_NAME=bthwani-runtime

BTHWANI_POSTGRES_IMAGE=postgres:16-alpine
BTHWANI_POSTGRES_CONTAINER=bthwani-postgres-runtime
BTHWANI_POSTGRES_PORT=55432
BTHWANI_POSTGRES_USER=bthwani_runtime
BTHWANI_POSTGRES_PASSWORD=bthwani_runtime_password
BTHWANI_POSTGRES_DB=bthwani_runtime

BTHWANI_DSH_API_CONTAINER=bthwani-dsh-api-runtime
BTHWANI_DSH_API_HOST_PORT=58080
BTHWANI_DSH_DB_USER=dsh_runtime
BTHWANI_DSH_DB_PASSWORD=dsh_runtime_password
BTHWANI_DSH_DB_NAME=dsh_runtime
DSH_WLT_BASE_URL=http://wlt-api:8083

BTHWANI_WLT_API_CONTAINER=bthwani-wlt-api-runtime
BTHWANI_WLT_API_HOST_PORT=58083
BTHWANI_WLT_DB_USER=wlt_runtime
BTHWANI_WLT_DB_PASSWORD=wlt_runtime_password
BTHWANI_WLT_DB_NAME=wlt_runtime

BTHWANI_MINIO_IMAGE=minio/minio:RELEASE.2024-11-07T00-52-20Z
BTHWANI_MINIO_CONTAINER=bthwani-minio-runtime
BTHWANI_MINIO_API_PORT=57000
BTHWANI_MINIO_CONSOLE_PORT=57001
BTHWANI_MINIO_ROOT_USER=bthwani_minio
BTHWANI_MINIO_ROOT_PASSWORD=bthwani_minio_password
