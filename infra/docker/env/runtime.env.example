COMPOSE_PROJECT_NAME=bthwani-runtime

BTHWANI_POSTGRES_IMAGE=postgres:16-alpine
BTHWANI_POSTGRES_CONTAINER=bthwani-postgres-runtime
BTHWANI_POSTGRES_PORT=55432
BTHWANI_POSTGRES_USER=bthwani_runtime
BTHWANI_POSTGRES_PASSWORD=bthwani_runtime_password
BTHWANI_POSTGRES_DB=bthwani_runtime

BTHWANI_DSH_API_CONTAINER=bthwani-dsh-api-runtime
BTHWANI_DSH_API_HOST_PORT=58080
BTHWANI_DSH_DB_USER=dsh_runtime
BTHWANI_DSH_DB_PASSWORD=dsh_runtime_password
BTHWANI_DSH_DB_NAME=dsh_runtime
DSH_WLT_BASE_URL=http://wlt-api:8083
WLT_DSH_SERVICE_TOKEN=dev-only-dsh-wlt-shared-secret
DSH_WLT_SERVICE_TOKEN=dev-only-dsh-wlt-shared-secret
WLT_DSH_BASE_URL=http://dsh-api:8080

BTHWANI_WLT_API_CONTAINER=bthwani-wlt-api-runtime
BTHWANI_WLT_API_HOST_PORT=58083
BTHWANI_WLT_DB_USER=wlt_runtime
BTHWANI_WLT_DB_PASSWORD=wlt_runtime_password
BTHWANI_WLT_DB_NAME=wlt_runtime
WLT_FINANCIAL_PROVIDER_MODE=mock
WLT_FINANCIAL_PROVIDER_BASE_URL=http://wiremock-financial-provider:8080
WLT_ALLOW_PRODUCTION_PROVIDER=false
WLT_MUTATIONS_ENABLED=true
WLT_PAYOUT_ENCRYPTION_KEY=dev-only-payout-destination-encryption-key

BTHWANI_WIREMOCK_IMAGE=wiremock/wiremock:3.13.2
BTHWANI_WIREMOCK_FINANCIAL_CONTAINER=bthwani-wiremock-financial-provider-runtime
BTHWANI_WIREMOCK_FINANCIAL_PORT=58090
BTHWANI_MAILPIT_IMAGE=axllent/mailpit:v1.27.8
BTHWANI_MAILPIT_CONTAINER=bthwani-mailpit-runtime
BTHWANI_MAILPIT_UI_PORT=8025
BTHWANI_MAILPIT_SMTP_PORT=1025
BTHWANI_VALKEY_IMAGE=valkey/valkey:9.1.0-alpine
BTHWANI_VALKEY_CONTAINER=bthwani-valkey-runtime

BTHWANI_MINIO_IMAGE=minio/minio:RELEASE.2024-11-07T00-52-20Z
BTHWANI_MINIO_CONTAINER=bthwani-minio-runtime
BTHWANI_MINIO_API_PORT=59000
BTHWANI_MINIO_CONSOLE_PORT=59001
BTHWANI_MINIO_ROOT_USER=bthwani_minio
BTHWANI_MINIO_ROOT_PASSWORD=bthwani_minio_password

# Identity Activation HMAC secret (must be at least 32 bytes)
IDENTITY_ACTIVATION_HMAC_SECRET=LOCAL_ONLY_replace_with_32_plus_byte_activation_hmac_secret
IDENTITY_WORKFORCE_SERVICE_TOKEN=LOCAL_ONLY_replace_with_workforce_internal_service_token

BTHWANI_IDENTITY_API_CONTAINER=bthwani-identity-api-runtime
BTHWANI_IDENTITY_API_HOST_PORT=58082
BTHWANI_IDENTITY_DB_USER=identity_runtime
BTHWANI_IDENTITY_DB_PASSWORD=identity_runtime_password
BTHWANI_IDENTITY_DB_NAME=identity_runtime

BTHWANI_WORKFORCE_API_CONTAINER=bthwani-workforce-api-runtime
BTHWANI_WORKFORCE_API_HOST_PORT=58086
BTHWANI_WORKFORCE_DB_USER=workforce_runtime
BTHWANI_WORKFORCE_DB_PASSWORD=workforce_runtime_password
BTHWANI_WORKFORCE_DB_NAME=workforce_runtime

BTHWANI_PROVIDERS_API_CONTAINER=bthwani-providers-api-runtime
BTHWANI_PROVIDERS_API_HOST_PORT=58087
BTHWANI_PROVIDERS_DB_USER=providers_runtime
BTHWANI_PROVIDERS_DB_PASSWORD=providers_runtime_password
BTHWANI_PROVIDERS_DB_NAME=providers_runtime

BTHWANI_PLATFORM_CONTROL_API_CONTAINER=bthwani-platform-control-api-runtime
BTHWANI_PLATFORM_CONTROL_API_HOST_PORT=58088
BTHWANI_PLATFORM_CONTROL_DB_USER=platform_control_runtime
BTHWANI_PLATFORM_CONTROL_DB_PASSWORD=platform_control_runtime_password
BTHWANI_PLATFORM_CONTROL_DB_NAME=platform_control_runtime
