# runtime.local-production.env
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL PRODUCTION-LIKE ENVIRONMENT — DO NOT COMMIT THIS FILE.
# Generated by: infra/docker/scripts/generate-local-production-env.ps1
# All secrets are randomly generated for local use only.
# Swap with real provider credentials before any real production deployment.
# ─────────────────────────────────────────────────────────────────────────────

COMPOSE_PROJECT_NAME=bthwani-local-production

# ── Postgres ──────────────────────────────────────────────────────────────────
BTHWANI_POSTGRES_IMAGE=postgres:16-alpine
BTHWANI_POSTGRES_CONTAINER=bthwani-postgres-local-prod
BTHWANI_POSTGRES_PORT=55432
BTHWANI_POSTGRES_USER=bthwani_prod
BTHWANI_POSTGRES_PASSWORD=REPLACE_WITH_GENERATED_PG_PASSWORD
BTHWANI_POSTGRES_DB=bthwani_prod

# ── DSH API ───────────────────────────────────────────────────────────────────
BTHWANI_DSH_API_CONTAINER=bthwani-dsh-api-local-prod
BTHWANI_DSH_API_HOST_PORT=58080
BTHWANI_DSH_DB_USER=dsh_prod
BTHWANI_DSH_DB_PASSWORD=REPLACE_WITH_GENERATED_DSH_DB_PASSWORD
BTHWANI_DSH_DB_NAME=dsh_prod
DSH_WLT_BASE_URL=http://wlt-api:8083
WLT_DSH_BASE_URL=http://dsh-api:8080

# ── WLT API ───────────────────────────────────────────────────────────────────
BTHWANI_WLT_API_CONTAINER=bthwani-wlt-api-local-prod
BTHWANI_WLT_API_HOST_PORT=58083
BTHWANI_WLT_DB_USER=wlt_prod
BTHWANI_WLT_DB_PASSWORD=REPLACE_WITH_GENERATED_WLT_DB_PASSWORD
BTHWANI_WLT_DB_NAME=wlt_prod
WLT_FINANCIAL_PROVIDER_MODE=mock
WLT_FINANCIAL_PROVIDER_BASE_URL=http://wiremock-financial-provider:8080
WLT_ALLOW_PRODUCTION_PROVIDER=false
# Commercial/financial mutations are approved for this isolated mock-backed
# production-like verification environment. Real production must set this
# explicitly only after provider credentials, service tokens and release gates
# are verified.
WLT_MUTATIONS_ENABLED=true

# ── Service-to-Service Tokens ──────────────────────────────────────────────────
# Generated: 64 random hex chars each. Must match on both sides of the boundary.
WLT_DSH_SERVICE_TOKEN=REPLACE_WITH_GENERATED_WLT_DSH_SERVICE_TOKEN
DSH_WLT_SERVICE_TOKEN=REPLACE_WITH_GENERATED_DSH_WLT_SERVICE_TOKEN

# ── Identity ──────────────────────────────────────────────────────────────────
BTHWANI_IDENTITY_API_CONTAINER=bthwani-identity-api-local-prod
BTHWANI_IDENTITY_API_HOST_PORT=58082
BTHWANI_IDENTITY_DB_USER=identity_prod
BTHWANI_IDENTITY_DB_PASSWORD=REPLACE_WITH_GENERATED_IDENTITY_DB_PASSWORD
BTHWANI_IDENTITY_DB_NAME=identity_prod
IDENTITY_ACTIVATION_HMAC_SECRET=REPLACE_WITH_GENERATED_HMAC_SECRET_32BYTES
IDENTITY_WORKFORCE_SERVICE_TOKEN=REPLACE_WITH_GENERATED_WORKFORCE_SERVICE_TOKEN

# ── Workforce ─────────────────────────────────────────────────────────────────
BTHWANI_WORKFORCE_API_CONTAINER=bthwani-workforce-api-local-prod
BTHWANI_WORKFORCE_API_HOST_PORT=58086
BTHWANI_WORKFORCE_DB_USER=workforce_prod
BTHWANI_WORKFORCE_DB_PASSWORD=REPLACE_WITH_GENERATED_WORKFORCE_DB_PASSWORD
BTHWANI_WORKFORCE_DB_NAME=workforce_prod

# ── WireMock (financial simulator — dev/staging only) ─────────────────────────
BTHWANI_WIREMOCK_IMAGE=wiremock/wiremock:3.13.2
BTHWANI_WIREMOCK_FINANCIAL_CONTAINER=bthwani-wiremock-financial-provider-local-prod
BTHWANI_WIREMOCK_FINANCIAL_PORT=58090

# ── Mailpit (local SMTP trap) ─────────────────────────────────────────────────
BTHWANI_MAILPIT_IMAGE=axllent/mailpit:v1.27.8
BTHWANI_MAILPIT_CONTAINER=bthwani-mailpit-local-prod
BTHWANI_MAILPIT_UI_PORT=8025
BTHWANI_MAILPIT_SMTP_PORT=1025

# ── Valkey (cache) ────────────────────────────────────────────────────────────
BTHWANI_VALKEY_IMAGE=valkey/valkey:9.1.0-alpine
BTHWANI_VALKEY_CONTAINER=bthwani-valkey-local-prod

# ── MinIO (object storage) ────────────────────────────────────────────────────
BTHWANI_MINIO_IMAGE=minio/minio:RELEASE.2024-11-07T00-52-20Z
BTHWANI_MINIO_CONTAINER=bthwani-minio-local-prod
BTHWANI_MINIO_API_PORT=59000
BTHWANI_MINIO_CONSOLE_PORT=59001
BTHWANI_MINIO_ROOT_USER=bthwani_minio_prod
BTHWANI_MINIO_ROOT_PASSWORD=REPLACE_WITH_GENERATED_MINIO_PASSWORD
