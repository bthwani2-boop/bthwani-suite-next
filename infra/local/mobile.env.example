# Copy this file to infra/local/mobile.env. The target file is ignored by Git.
# Never commit real DSNs, auth tokens, Firebase files, or provider credentials.

# Shared Sentry organization. Organization and project names are configuration,
# while SENTRY_AUTH_TOKEN is a secret used only for source-map upload during builds.
SENTRY_ORG=
SENTRY_URL=https://sentry.io/
SENTRY_AUTH_TOKEN=

# One Sentry project and public DSN per mobile application.
SENTRY_PROJECT_APP_CLIENT=
EXPO_PUBLIC_SENTRY_DSN_APP_CLIENT=

SENTRY_PROJECT_APP_PARTNER=
EXPO_PUBLIC_SENTRY_DSN_APP_PARTNER=

SENTRY_PROJECT_APP_CAPTAIN=
EXPO_PUBLIC_SENTRY_DSN_APP_CAPTAIN=

SENTRY_PROJECT_APP_FIELD=
EXPO_PUBLIC_SENTRY_DSN_APP_FIELD=

# Runtime observability policy.
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
EXPO_PUBLIC_SENTRY_DEBUG=false
# Set true for one launch only to emit a governed startup verification event.
EXPO_PUBLIC_SENTRY_STARTUP_PROBE=false

# Real Firebase configuration files are local/EAS file secrets. Do not place
# placeholder google-services.json files in the repository.
GOOGLE_SERVICES_JSON_APP_CLIENT=C:\secure\bthwani\app-client\google-services.json
GOOGLE_SERVICES_JSON_APP_PARTNER=C:\secure\bthwani\app-partner\google-services.json
GOOGLE_SERVICES_JSON_APP_CAPTAIN=C:\secure\bthwani\app-captain\google-services.json
GOOGLE_SERVICES_JSON_APP_FIELD=C:\secure\bthwani\app-field\google-services.json

# Backend startup is automatic by default. Set to 0 only when services are
# deliberately managed in a separate terminal.
BTHWANI_AUTO_START_BACKEND=1
