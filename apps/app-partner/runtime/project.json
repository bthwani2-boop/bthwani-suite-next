{
  "name": "app-partner",
  "root": "apps/app-partner/runtime",
  "sourceRoot": "apps/app-partner/runtime",
  "projectType": "application",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/run-command-check.mjs --label par-type -- pnpm --dir apps/app-partner/runtime typecheck"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/run-command-check.mjs --label app-partner-config -- node tools/scripts/guard-mobile-apps.mjs"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/export-mobile-app.mjs app-partner"
      }
    }
  },
  "tags": [
    "scope:app-partner",
    "type:app"
  ]
}
