{
  "name": "app-field",
  "root": "apps/app-field/runtime",
  "sourceRoot": "apps/app-field/runtime",
  "projectType": "application",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir apps/app-field/runtime typecheck"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/guard-mobile-apps.mjs"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/export-mobile-app.mjs app-field"
      }
    }
  },
  "tags": [
    "scope:app-field type:app"
  ]
}
