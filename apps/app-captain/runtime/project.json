{
  "name": "app-captain",
  "root": "apps/app-captain/runtime",
  "sourceRoot": "apps/app-captain/runtime",
  "projectType": "application",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir apps/app-captain/runtime typecheck"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/run-command-check.mjs --label app-captain-config -- node tools/scripts/guard-mobile-apps.mjs"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/export-mobile-app.mjs app-captain"
      }
    }
  },
  "tags": [
    "scope:app-captain",
    "type:app"
  ]
}
