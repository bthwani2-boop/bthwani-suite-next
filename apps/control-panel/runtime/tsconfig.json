{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": false,
    "types": ["node", "react", "react-dom"],
    "paths": {
      "@bthwani/app-shell": ["../../../shared/app-shell/src/index.ts"],
      "@bthwani/core-identity": ["../../../core/identity/clients/index.ts"],
      "@bthwani/core-identity/server": ["../../../core/identity/clients/identity-client.ts"],
      "@bthwani/core-platform-control": ["../../../core/platform-control/clients/generated/platform-control-api.ts"],
      "@bthwani/core-providers": ["../../../core/providers/clients/generated/providers-api.ts"],
      "@bthwani/ui-kit": ["../../../shared/ui-kit/src/index.ts"],
      "@bthwani/ui-kit/web": ["../../../shared/ui-kit/src/web.ts"],
      "@bthwani/ui-kit/tokens": ["../../../shared/ui-kit/src/tokens/index.ts"],
      "@bthwani/control-panel/shell": ["./src/shell/index.ts"],
      "@bthwani/control-panel/components": ["./src/components/index.ts"],
      "@dsh-cp/*": ["../../../services/dsh/frontend/control-panel/*"],
      "@dsh-shared/*": ["../../../services/dsh/frontend/shared/*"],
      "@dsh-clients/*": ["../../../services/dsh/clients/*"],
      "react-native": ["../../app-client/runtime/node_modules/react-native"],
      "expo-image-picker": ["../../app-field/runtime/node_modules/expo-image-picker"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "dist", "build"]
}
