{
  "name": "control-panel",
  "root": "apps/control-panel/runtime",
  "sourceRoot": "apps/control-panel/runtime",
  "projectType": "application",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/run-tsc-check.mjs --project apps/control-panel/runtime/tsconfig.json --label control-panel"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --test apps/control-panel/runtime/tests/*.test.mjs"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir apps/control-panel/runtime build && pnpm run performance:bundle:size"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir apps/control-panel/runtime dev"
      }
    }
  },
  "tags": [
    "scope:control-panel",
    "type:app"
  ]
}
