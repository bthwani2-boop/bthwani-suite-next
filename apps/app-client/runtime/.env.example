# Copy this file to .env and fill in your local values.
# EXPO_PUBLIC_* vars are embedded at bundle time by Metro.
# After editing, restart the Expo dev server with: pnpm start --clear

# Physical device (same WiFi as dev machine): replace with your machine's LAN IP
# Android emulator: http://10.0.2.2:58080
# iOS simulator: http://localhost:58080
EXPO_PUBLIC_DSH_API_BASE_URL=http://<MACHINE_LAN_IP>:58080
