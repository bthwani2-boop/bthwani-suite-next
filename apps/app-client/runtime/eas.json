{
  "cli": {
    "appVersionSource": "local"
  },
  "build": {
    "base": {
      "node": "24.17.0",
      "env": {
        "COREPACK_ENABLE_DOWNLOAD_PROMPT": "0",
        "EAS_SKIP_AUTO_FINGERPRINT": "1"
      },
      "pnpm": "11.7.0",
      "corepack": true
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "extends": "base",
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
