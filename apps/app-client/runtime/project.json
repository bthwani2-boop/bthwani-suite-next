{
  "name": "app-client",
  "root": "apps/app-client/runtime",
  "sourceRoot": "apps/app-client/runtime",
  "projectType": "application",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/run-tsc-check.mjs --project apps/app-client/runtime/tsconfig.json --label app-client"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "node tools/scripts/run-command-check.mjs --label app-client-contracts -- node --test apps/app-client/runtime/tests/*.test.mjs",
          "node tools/scripts/run-command-check.mjs --label mobile-config -- node tools/scripts/guard-mobile-apps.mjs"
        ],
        "parallel": false
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/export-mobile-app.mjs app-client"
      }
    }
  },
  "tags": [
    "scope:app-client",
    "type:app"
  ]
}
