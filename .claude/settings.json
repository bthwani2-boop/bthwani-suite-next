{
  "project": "bthwani-suite-next",
  "instructions": [
    "AGENTS.md",
    ".agents/INDEX.md",
    ".agents/AUTHORITY_BOUNDARY.md"
  ],
  "permissions": {
    "allow": [
      "Bash(*)",
      "PowerShell(*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .agents/hooks/graphify-pretool.ps1"
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .agents/hooks/graphify-pretool.ps1"
          }
        ]
      }
    ]
  }
}