{
  "permissions": {
    "allow": [
      "Bash(xargs -I{} sh -c 'echo ==={}===; cat {}')",
      "Bash(awk -F': ' '{print $2}')"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/b/AppData/Roaming/npm/node_modules/lean-ctx-bin/bin/lean-ctx.exe hook observe"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/b/AppData/Roaming/npm/node_modules/lean-ctx-bin/bin/lean-ctx.exe hook observe"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|bash|PowerShell|powershell",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/b/AppData/Roaming/npm/node_modules/lean-ctx-bin/bin/lean-ctx.exe hook rewrite"
          }
        ]
      },
      {
        "matcher": "Read|read|ReadFile|read_file|View|view|Grep|grep|Search|search|ListFiles|list_files|ListDirectory|list_directory",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/b/AppData/Roaming/npm/node_modules/lean-ctx-bin/bin/lean-ctx.exe hook redirect"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/b/AppData/Roaming/npm/node_modules/lean-ctx-bin/bin/lean-ctx.exe hook observe"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "C:/Users/b/AppData/Roaming/npm/node_modules/lean-ctx-bin/bin/lean-ctx.exe hook observe"
          }
        ]
      }
    ]
  }
}
