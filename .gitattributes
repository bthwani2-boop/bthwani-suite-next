# Evidence files contain raw API/command output that legitimately has trailing whitespace.
services/*/evidence/**  -whitespace
tools/registry/runs/**  -whitespace

# Linux-executed scripts must stay LF. CRLF breaks /bin/sh inside Docker.
*.sh text eol=lf
infra/data-plane/postgres/init/*.sh text eol=lf
# Workspace portability / cross-device line endings
* text=auto
*.json text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.ps1 text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.txt text eol=lf
*.env text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
