{
  "name": "@bthwani/ui-kit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./web": "./src/web.ts",
    "./mobile": "./src/mobile.tsx",
    "./next": "./src/next.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:contracts": "tsc --noEmit -p tsconfig.contracts.json",
    "lint": "node ../../tools/guards/no-cp-primitives-in-ui-kit.mjs && node ../../tools/guards/no-domain-component-in-ui-kit.mjs && node ../../tools/guards/no-direct-tamagui-outside-ui-kit.mjs && node ../../tools/guards/no-ui-kit-deep-imports.mjs"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "typescript": "~6.0.3"
  },
  "dependencies": {
    "@tamagui/config": "2.3.3",
    "tamagui": "2.3.3"
  },
  "peerDependencies": {
    "react": ">=19 <20",
    "react-dom": ">=19 <20",
    "react-native": ">=0.81 <1"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  }
}
