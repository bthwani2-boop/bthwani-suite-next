{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "outDir": "dist-jrn-033",
    "module": "ESNext",
    "jsx": "react-jsx",
    "types": ["node", "react", "react-dom"],
    "paths": {
      "@bthwani/ui-kit": ["shared/ui-kit/src/index.ts"],
      "@bthwani/ui-kit/web": ["shared/ui-kit/src/web.ts"],
      "@bthwani/ui-kit/tokens": ["shared/ui-kit/src/tokens/index.ts"],
      "@bthwani/app-shell": ["shared/app-shell/src/index.ts"],
      "@bthwani/control-panel/components": ["apps/control-panel/runtime/src/components/index.ts"],
      "@bthwani/control-panel/shell": ["apps/control-panel/runtime/src/shell/index.ts"],
      "@dsh-cp/*": ["services/dsh/frontend/control-panel/*"],
      "@dsh-shared/*": ["services/dsh/frontend/shared/*"],
      "react-native": ["apps/app-client/runtime/node_modules/react-native"]
    }
  },
  "include": [
    "frontend/**/*.d.ts",
    "frontend/shared/_kernel/**/*.ts",
    "frontend/shared/_kernel/**/*.tsx",
    "frontend/shared/finance-wlt-link/actor-wallet/**/*.ts",
    "frontend/shared/finance-wlt-link/actor-wallet/**/*.tsx",
    "frontend/shared/finance-wlt-link/field-finance/**/*.ts",
    "frontend/shared/finance-wlt-link/field-finance/**/*.tsx",
    "frontend/shared/finance-wlt-link/wlt/generated/WltDshPartnerBridge.tsx",
    "frontend/shared/finance-wlt-link/wlt/generated/WltDshCaptainBridge.tsx",
    "frontend/shared/finance-wlt-link/wlt/generated/wlt_frontend_dsh_app_captain.facade.ts",
    "frontend/app-client/account/MySpaceScreen.tsx",
    "frontend/app-captain/account/DshCaptainFinanceScreen.tsx",
    "frontend/app-field/finance/DshFieldFinanceScreen.tsx",
    "frontend/control-panel/finance/**/*.ts",
    "frontend/control-panel/finance/**/*.tsx",
    "../../apps/control-panel/runtime/src/app/dsh/finance/page.tsx"
  ],
  "exclude": ["node_modules", "dist", "dist-jrn-033"]
}
