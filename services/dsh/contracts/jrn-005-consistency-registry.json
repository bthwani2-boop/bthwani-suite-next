  ],
  "sameCommitVerificationContexts": [
    "journeys/jrn-005/all-slices"
  ],
  "conflictPolicy": "Return ADDRESS_CONFLICT for stale versions and ADDRESS_ALREADY_EXISTS for an active logical duplicate; the client must keep committed state authoritative.",
  "successPolicy": "The surface reports success only after the canonical mutation response and a refreshed persisted address list.",
  "formalClosureRequires": [
    "same-commit PostgreSQL 16 migration and invariant execution",
    "same-commit targeted static, Go and TypeScript verification",
    "device visual, RTL, accessibility and weak-network evidence",
    "independent Product, QA, Security, Privacy, Accessibility and Release approvals"
  ]
