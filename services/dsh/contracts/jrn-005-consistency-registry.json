{
  "schemaVersion": 1,
  "journeyId": "JRN-005",
  "journeyName": "Client address book",
  "truthOwner": "DSH persisted client-owned delivery addresses",
  "canonicalContract": "services/dsh/contracts/dsh.client-address.openapi.yaml",
  "databaseTruth": {
    "table": "dsh_client_addresses",
    "singleDefaultIndex": "uq_dsh_client_addresses_single_default",
