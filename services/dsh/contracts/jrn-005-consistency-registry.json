  "operationsRunbook": "governance/runbooks/JRN-005_CLIENT_ADDRESS_OPERATIONS.md",
  "databaseTruth": {
    "table": "dsh_client_addresses",
    "eventsTable": "dsh_client_address_events",
    "singleDefaultIndex": "uq_dsh_client_addresses_single_default",
    "activeIdempotencyIndex": "uq_dsh_client_addresses_active_idempotency",
    "activeLogicalUniquenessIndex": "uq_dsh_client_addresses_active_fingerprint",
    "logicalFingerprintMigration": "services/dsh/database/migrations/dsh-901_client_address_logical_deduplication.sql",
    "serviceAreaBindingMigration": "services/dsh/database/migrations/dsh-906_jrn_006_client_address_geofence_binding.sql",
    "privacyMigration": "services/dsh/database/migrations/dsh-081_client_address_subject_anonymization.sql"
  },
  "requiredCapabilities": [
    "list-owned-addresses",
    "create-idempotently",
    "prevent-active-logical-duplicates",
    "update-with-optimistic-concurrency",
    "soft-delete-with-default-recovery",
    "set-one-default",
    "verify-service-area-before-write",
    "anonymize-expired-soft-deleted-pii",
    "checkout-owned-address-readback"
  ],
  "requiredReadAfterWrite": [
    "create-address-then-list",
    "update-address-then-list",
    "delete-address-then-list",
    "set-default-then-list"
  ],
  "requiredVisibleStates": [
    "loading",
    "empty",
    "ready",
    "network-retry",
    "unauthenticated",
    "not-found",
    "conflict",
    "duplicate-address-recovery",
    "service-area-unverified",
    "mutating"
  ],
  "forbiddenTruthSources": [
    "AsyncStorage address records",
    "localStorage address records",
    "sessionStorage address records",
    "MMKV address records",
    "screen fixtures",
    "screen mocks",
    "cart-owned address copies",
    "client-supplied checkout address snapshots"
  ],
  "requiredVerification": [
    "services/dsh/tests/jrn-005-all-slices.test.mjs",
    "services/dsh/tests/tsconfig.jrn-005-app-client.json",
    "services/dsh/backend/internal/http/client_addresses_error_test.go",
    "services/dsh/backend/internal/clientaddress/duplicate_error_test.go",
    "services/dsh/database/tests/dsh-901_client_address_logical_deduplication.sql",
