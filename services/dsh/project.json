{
  "name": "dsh",
  "root": "services/dsh",
  "sourceRoot": "services/dsh",
  "projectType": "application",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/run-tsc-check.mjs --project services/dsh/tsconfig.json --label dsh"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir services/dsh build"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir services/dsh lint"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --dir services/dsh build && node --test services/dsh/tests/*.test.mjs"
      }
    }
  },
  "tags": [
    "scope:dsh",
    "type:service"
  ]
}
