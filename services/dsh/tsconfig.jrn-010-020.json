{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "outDir": "dist-jrn-010-020",
    "paths": {
      "@bthwani/ui-kit": ["shared/ui-kit/src/index.ts"],
      "@bthwani/ui-kit/web": ["shared/ui-kit/src/web.ts"],
      "@bthwani/ui-kit/tokens": ["shared/ui-kit/src/tokens/index.ts"],
      "@bthwani/app-shell": ["shared/app-shell/src/index.ts"],
      "@bthwani/core-identity": ["core/identity/clients/index.ts"],
      "@bthwani/core-platform-control": ["core/platform-control/clients/generated/platform-control-api.ts"],
      "@bthwani/core-providers": ["core/providers/clients/generated/providers-api.ts"],
      "@bthwani/app-captain-runtime": ["apps/app-captain/runtime/src/index.ts"],
      "@bthwani/app-client-runtime": ["apps/app-client/runtime/src/index.ts"],
      "@bthwani/app-field-runtime": ["apps/app-field/runtime/src/index.ts"],
      "@bthwani/app-partner-runtime": ["apps/app-partner/runtime/src/index.ts"],
      "@dsh-shared/session/control-panel-session": ["services/dsh/frontend/shared/session/control-panel-session.tsx"],
      "@dsh-shared/session/control-panel-permissions": ["services/dsh/frontend/shared/session/control-panel-permissions.ts"],
      "react-native": ["apps/app-client/runtime/node_modules/react-native"],
      "expo-image-picker": ["apps/app-field/runtime/node_modules/expo-image-picker"],
      "expo-location": ["apps/app-field/runtime/node_modules/expo-location"],
      "expo-secure-store": ["apps/app-field/runtime/node_modules/expo-secure-store"]
    }
  },
  "include": [
    "frontend/**/*.d.ts",
    "frontend/shared/_kernel/**/*.ts",
    "frontend/shared/_kernel/**/*.tsx",
    "frontend/shared/session/control-panel-session.tsx",
    "frontend/shared/session/control-panel-session.api.ts",
    "frontend/shared/session/control-panel-permissions.ts",
    "frontend/shared/home-discovery/home-discovery.types.ts",
    "frontend/shared/checkout/**/*.ts",
    "frontend/shared/checkout/**/*.tsx",
    "frontend/shared/order-truth/**/*.ts",
    "frontend/shared/order-truth/**/*.tsx",
    "frontend/shared/orders/**/*.ts",
    "frontend/shared/orders/**/*.tsx",
    "frontend/shared/dispatch/**/*.ts",
    "frontend/shared/dispatch/**/*.tsx",
    "frontend/shared/pickup/**/*.ts",
    "frontend/shared/pickup/**/*.tsx",
    "frontend/shared/delivery/**/*.ts",
    "frontend/shared/delivery/**/*.tsx",
    "frontend/shared/partner-delivery/**/*.ts",
    "frontend/shared/partner-delivery/**/*.tsx",
    "frontend/shared/media/pod/**/*.ts",
    "frontend/shared/media/pod/**/*.tsx",
    "frontend/shared/operations/**/*.ts",
    "frontend/shared/operations/**/*.tsx",
    "frontend/shared/workforce/workforce.api.ts",
    "frontend/shared/workforce/workforce.types.ts",
    "frontend/app-client/orders/**/*.ts",
    "frontend/app-client/orders/**/*.tsx",
    "frontend/app-partner/orders/**/*.ts",
    "frontend/app-partner/orders/**/*.tsx",
    "frontend/app-captain/orders/**/*.ts",
    "frontend/app-captain/orders/**/*.tsx",
    "frontend/control-panel/operations/**/*.ts",
    "frontend/control-panel/operations/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-jrn-010-020"
  ]
}
