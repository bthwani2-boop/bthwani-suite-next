{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "module": "CommonJS",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "../../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-native",
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "clients/**/*.ts",
    "frontend/**/*.d.ts",
    "frontend/shared/**/*.ts",
    "frontend/shared/**/*.tsx",
    "frontend/app-client/**/*.ts",
    "frontend/app-client/**/*.tsx",
    "frontend/app-partner/**/*.ts",
    "frontend/app-partner/**/*.tsx",
    "frontend/app-field/**/*.ts",
    "frontend/app-field/**/*.tsx",
    "frontend/app-captain/**/*.ts",
    "frontend/app-captain/**/*.tsx",
    "frontend/control-panel/**/*.ts",
    "frontend/control-panel/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
