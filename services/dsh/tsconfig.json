{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "react-native",
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "domain/**/*.ts",
    "backend/**/*.ts",
    "clients/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
