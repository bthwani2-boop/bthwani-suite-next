{
  "name": "bthwani-suite-next",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.34.2",
  "engines": {
    "node": ">=24.17.0 <25",
    "pnpm": "10.34.2"
  },
  "scripts": {
    "contracts:lint": "node tools/important-scripts/contracts-foundation.mjs",
    "foundation:gate": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/scripts/run-foundation-gate.ps1",
    "typecheck": "pnpm -r --if-present typecheck",
    "build": "pnpm -r --if-present build",
    "slice:gate": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/scripts/run-slice-gate.ps1",
    "guard:foundation": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/scripts/run-foundation-gate.ps1",
    "guard:slice": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/scripts/run-slice-gate.ps1",
    "docker:runtime:up": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/up-runtime.ps1",
    "docker:runtime:down": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/down-runtime.ps1",
    "docker:runtime:reset": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/reset-runtime.ps1",
    "docker:runtime:smoke": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/smoke-runtime.ps1",
    "guard:matrix:v2": "node tools/guards/guard-slice-master-matrix-v2.mjs",
    "guard:matrix:v3": "node tools/guards/guard-slice-master-matrix-v3.mjs",
    "graphify": "graphify update . --force",
    "graphify:callflow": "graphify export callflow-html",
    "graphify:version": "graphify --version",
    "graphify:code": "graphify update . --force",
    "graphify:full": "graphify .",
    "nx:projects": "nx show projects",
    "nx:graph": "nx graph",
    "nx:typecheck": "nx run-many -t typecheck --all",
    "nx:build": "nx run-many -t build --all",
    "nx:lint": "nx run-many -t lint --all",
    "nx:test": "nx run-many -t test --all",
    "affected:typecheck": "nx affected -t typecheck",
    "affected:build": "nx affected -t build",
    "affected:lint": "nx affected -t lint",
    "affected:test": "nx affected -t test",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "mobile:expo:verify": "node tools/scripts/guard-mobile-apps.mjs",
    "mobile:eas:preflight": "node tools/scripts/sync-mobile-apps.mjs --check && node tools/scripts/guard-mobile-apps.mjs && pnpm -r --if-present typecheck",
    "mobile:apps:sync": "node tools/scripts/sync-mobile-apps.mjs --apply",
    "mobile:eas:build:captain:dev": "pnpm --dir apps/app-captain/runtime dlx eas-cli@latest build --platform android --profile development --clear-cache --non-interactive",
    "mobile:eas:build:field:dev": "pnpm --dir apps/app-field/runtime dlx eas-cli@latest build --platform android --profile development --clear-cache --non-interactive",
    "mobile:eas:build": "node tools/scripts/eas-build-mobile.mjs"
  },
  "devDependencies": {
    "@ast-grep/cli": "0.43.0",
    "@stoplight/spectral-cli": "6.16.0",
    "@types/react": "19.2.17",
    "dependency-cruiser": "17.4.3",
    "jscpd": "5.0.10",
    "knip": "6.17.1",
    "madge": "8.0.0",
    "openapi-typescript": "7.13.0",
    "sherif": "1.11.1",
    "typescript": "~6.0.3",
    "nx": "22.3.3"
  }
}
