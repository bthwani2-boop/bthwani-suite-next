{
  "name": "bthwani-suite-next",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.34.2",
  "engines": {
    "node": ">=24.17.0 <25",
    "pnpm": "10.34.2"
  },
  "scripts": {
    "contracts:lint": "node tools/important-scripts/contracts-foundation.mjs",
    "foundation:gate": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/scripts/run-foundation-gate.ps1",
    "typecheck": "pnpm -r --if-present typecheck",
    "build": "pnpm -r --if-present build",
    "journey:gate": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/scripts/run-journey-gate.ps1",
    "guard:foundation": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/scripts/run-foundation-gate.ps1",
    "guard:journey": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/scripts/run-journey-gate.ps1",
    "docker:runtime:up": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action up -Profiles dsh,media",
    "docker:runtime:down": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action down -Profiles dsh,media",
    "docker:runtime:reset": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action reset -Profiles dsh,media",
    "docker:runtime:smoke": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action smoke -Profiles dsh,media",
    "runtime:full": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action all -Profiles identity,dsh,wlt,financial-simulators,mail,media",
    "runtime:full:up": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action up -Profiles identity,dsh,wlt,financial-simulators,mail,media",
    "runtime:full:down": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action down -Profiles identity,dsh,wlt,financial-simulators,mail,media",
    "runtime:full:reset": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action reset -Profiles identity,dsh,wlt,financial-simulators,mail,media",
    "runtime:full:smoke": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action smoke -Profiles identity,dsh,wlt,financial-simulators,mail,media",
    "runtime:up": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action up -Profiles dsh,media",
    "runtime:down": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action down -Profiles dsh,media",
    "runtime:reset": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action reset -Profiles dsh,media",
    "runtime:migrate": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action migrate -Profiles dsh",
    "runtime:seed": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action seed -Profiles dsh",
    "runtime:smoke": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action smoke -Profiles dsh,media",
    "runtime:status": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action status -Profiles dsh,media",
    "runtime:logs": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action logs -Profiles dsh,media",
    "runtime:all": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action all -Profiles dsh,media",
    "runtime:identity": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action all -Profiles identity",
    "runtime:identity:status": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action status -Profiles identity",
    "runtime:identity:smoke": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action smoke -Profiles identity",
    "runtime:codespaces:check": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/scripts/check-codespaces-runtime.ps1",
    "runtime:codespaces:core": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action up -Profiles dsh",
    "runtime:codespaces:wlt": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action up -Profiles wlt",
    "runtime:codespaces:smoke": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action smoke -Profiles dsh,wlt",
    "guard:ui-kit-boundary": "node tools/guards/ui-kit-boundary-gate.mjs",
    "guard:fullstack-boundary": "node tools/guards/fullstack-boundary-gate.mjs",
    "guard:wlt-financial-boundary": "node tools/guards/wlt-financial-boundary-gate.mjs",
    "guard:runtime-config": "node tools/guards/runtime-config-gate.mjs",
    "guard:no-broken-imports": "node tools/guards/no-broken-imports.mjs",
    "guard:cleanup-policy": "node tools/guards/cleanup-policy-gate.mjs",
    "runtime:wlt": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action all -Profiles wlt",
    "runtime:wlt:up": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action up -Profiles wlt",
    "runtime:wlt:down": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action down -Profiles wlt",
    "runtime:wlt:status": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action status -Profiles wlt",
    "runtime:wlt:migrate": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action migrate -Profiles wlt",
    "runtime:wlt:seed": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action seed -Profiles wlt",
    "runtime:wlt:smoke": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action smoke -Profiles wlt",
    "runtime:dev-core": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action all -Profiles dsh",
    "runtime:financial-simulators": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action up -Profiles financial-simulators",
    "runtime:mail": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action up -Profiles mail",
    "runtime:cache": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action up -Profiles cache",
    "runtime:dev-financial": "pwsh -NoProfile -ExecutionPolicy Bypass -File infra/docker/scripts/runtime.ps1 -Action all -Profiles wlt,financial-simulators,mail",
    "runtime:wiremock:financial:smoke": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/scripts/smoke-wiremock-financial-provider.ps1",
    "runtime:wlt:provider:smoke": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/scripts/smoke-wlt-provider-through-wlt.ps1",
    "runtime:context:status": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/scripts/docker-context-status.ps1",
    "runtime:context:local": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/scripts/docker-context-local.ps1",
    "runtime:context:remote": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/scripts/docker-context-remote.ps1",
    "graphify": "graphify update . --force",
    "graphify:callflow": "graphify export callflow-html",
    "graphify:version": "graphify --version",
    "graphify:code": "graphify update . --force",
    "graphify:full": "graphify .",
    "nx:projects": "nx show projects",
    "nx:graph": "nx graph",
    "nx:typecheck": "nx run-many -t typecheck --all",
    "nx:build": "nx run-many -t build --all",
    "nx:lint": "nx run-many -t lint --all",
    "nx:test": "nx run-many -t test --all",
    "affected:typecheck": "nx affected -t typecheck",
    "affected:build": "nx affected -t build",
    "affected:lint": "nx affected -t lint",
    "affected:test": "nx affected -t test",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "mobile:expo:verify": "node tools/scripts/guard-mobile-apps.mjs",
    "mobile:eas:preflight": "node tools/scripts/sync-mobile-apps.mjs --check && node tools/scripts/guard-mobile-apps.mjs && pnpm -r --if-present typecheck",
    "mobile:apps:sync": "node tools/scripts/sync-mobile-apps.mjs --apply",
    "mobile:eas:build:captain:dev": "pnpm --dir apps/app-captain/runtime dlx eas-cli@latest build --platform android --profile development --clear-cache --non-interactive",
    "mobile:eas:build:field:dev": "pnpm --dir apps/app-field/runtime dlx eas-cli@latest build --platform android --profile development --clear-cache --non-interactive",
    "mobile:eas:build": "node tools/scripts/eas-build-mobile.mjs",
    "reverse": "pwsh -NoProfile -ExecutionPolicy Bypass -File apps/reverse-all.ps1",
    "client": "pwsh -NoProfile -ExecutionPolicy Bypass -File apps/app-client/runtime/start.ps1",
    "captain": "pwsh -NoProfile -ExecutionPolicy Bypass -File apps/app-captain/runtime/start.ps1",
    "field": "pwsh -NoProfile -ExecutionPolicy Bypass -File apps/app-field/runtime/start.ps1",
    "partner": "pwsh -NoProfile -ExecutionPolicy Bypass -File apps/app-partner/runtime/start.ps1",
    "control": "pwsh -NoProfile -ExecutionPolicy Bypass -File apps/control-panel/runtime/start.ps1",
    "yagni:diagnostics": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/scripts/run-yagni-diagnostics.ps1",
    "openapi:generate:dsh": "pnpm dlx openapi-typescript@7.13.0 services/dsh/contracts/dsh.openapi.yaml -o services/dsh/clients/generated/dsh-api.ts",
    "openapi:generate:wlt": "pnpm dlx openapi-typescript@7.13.0 services/wlt/contracts/wlt.openapi.yaml -o services/wlt/clients/generated/wlt-api.ts",
    "openapi:generate:identity": "pnpm dlx openapi-typescript@7.13.0 core/identity/contracts/auth.openapi.yaml -o core/identity/clients/generated/identity-api.ts",
    "openapi:generate": "pnpm run openapi:generate:dsh && pnpm run openapi:generate:wlt && pnpm run openapi:generate:identity",
    "guard:api-binding": "node tools/guards/api-binding-gate.mjs",
    "guard:backend-api-binding": "node tools/guards/backend-api-binding-gate.mjs",
    "guard:service-manifest-drift": "node tools/guards/service-manifest-drift-gate.mjs",
    "runtime:frontend-binding:check": "node tools/scripts/check-frontend-binding-readiness.mjs",
    "swagger": "node tools/scripts/serve-swagger.mjs"
  },
  "devDependencies": {
    "@ast-grep/cli": "0.43.0",
    "@stoplight/spectral-cli": "6.16.0",
    "@types/react": "19.2.17",
    "babel-plugin-react-compiler": "1.0.0",
    "dependency-cruiser": "17.4.3",
    "eslint": "9.39.1",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "jscpd": "5.0.10",
    "knip": "6.17.1",
    "madge": "8.0.0",
    "nx": "22.3.3",
    "openapi-typescript": "7.13.0",
    "sherif": "1.11.1",
    "typescript": "~6.0.3"
  }
}
