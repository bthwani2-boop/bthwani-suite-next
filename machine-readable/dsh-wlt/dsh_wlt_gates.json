{
  "$schema": "dsh-wlt-gates/v1",
  "_meta": {
    "description": "Acceptance gates for DSH/WLT closure. Every gate must PASS before a slice is considered closed. No PASS without live runtime evidence.",
    "last_updated": "2026-06-21",
    "principle": "No gate may be declared PASS without live runtime evidence. PASS on placeholder or mock is FORBIDDEN."
  },
  "gates": {
    "FOUNDATION_GATE": {
      "id": "FOUNDATION_GATE",
      "name": "Foundation Gate",
      "command": "pnpm run foundation:gate",
      "also_known_as": "pnpm run guard:foundation",
      "script": "tools/scripts/run-foundation-gate.ps1",
      "required_before": "ANY_DSH_SLICE",
      "checks": [
        "contracts/master.openapi.yaml index-only (paths empty)",
        "shared/ui-kit package exists and exports valid",
        "shared/app-shell exists",
        "infra/docker/compose.runtime.yml present",
        "No forbidden ports (8080-8084, 3000) anywhere",
        "No financial mutations outside WLT",
        "guard:matrix:v3 passes on slice_execution_master_matrix_v3.csv"
      ],
      "evidence_path": "services/dsh/evidence/FOUNDATION/",
      "current_status": "PASS"
    },
    "CONTRACTS_LINT_GATE": {
      "id": "CONTRACTS_LINT_GATE",
      "name": "Contracts Lint Gate",
      "command": "pnpm contracts:lint",
      "script": "tools/important-scripts/contracts-foundation.mjs",
      "required_before": "ANY_DSH_SLICE",
      "checks": [
        "DSH OpenAPI valid (Spectral lint)",
        "WLT OpenAPI valid",
        "No breaking changes vs contract version",
        "Generated client is up-to-date"
      ],
      "current_status": "PASS"
    },
    "GUARD_MATRIX_V3": {
      "id": "GUARD_MATRIX_V3",
      "name": "Guard Matrix V3",
      "command": "pnpm run guard:matrix:v3",
      "script": "tools/guards/guard-slice-master-matrix-v3.mjs",
      "required_before": "ANY_DSH_SLICE",
      "checks": [
        "slice_execution_master_matrix_v3.csv has >= 1150 rows",
        "DSH-001 status = RUNTIME_VERIFIED",
        "DSH-002 status = RUNTIME_VERIFIED",
        "WLT lifecycle entries present",
        "20 validation rules pass"
      ],
      "current_status": "PASS"
    },
    "DSH_SLICE_GATE": {
      "id": "DSH_SLICE_GATE",
      "name": "DSH Slice Gate (per-slice)",
      "command": "pnpm run slice:gate",
      "script": "tools/scripts/run-slice-gate.ps1",
      "required_before": "SLICE_CLOSURE",
      "checks": [
        "Backend handler implemented and tested (Go unit tests PASS)",
        "DB migration applied successfully",
        "Seed data inserted",
        "API smoke returns expected data",
        "Frontend screens render (no crash)",
        "No direct fetch in screen components",
        "All components from ui-kit (no local Tamagui)",
        "No hardcoded old ports",
        "No mock/demo/preview runtime data",
        "No fake actor IDs",
        "Tests > 0 and real (not placeholder)"
      ],
      "current_status": "PER_SLICE"
    },
    "DOCKER_RUNTIME_GATE": {
      "id": "DOCKER_RUNTIME_GATE",
      "name": "Docker Runtime Gate",
      "command": "pnpm runtime:all && pnpm runtime:status",
      "script": "infra/docker/scripts/runtime.ps1",
      "required_before": "SLICE_CLOSURE",
      "checks": [
        "postgres container running on port 55432",
        "dsh-api container running on port 58080",
        "GET /dsh/health returns 200",
        "GET /dsh/readiness returns 200",
        "GET /dsh/stores returns real data (not empty, not mock)",
        "No old ports (8080-8084, 3000) exposed",
        "Single compose file (compose.runtime.yml)"
      ],
      "current_status": "PASS"
    },
    "DSH_API_GATE": {
      "id": "DSH_API_GATE",
      "name": "DSH API Smoke Gate",
      "commands": [
        "Invoke-RestMethod 'http://localhost:58080/dsh/health'",
        "Invoke-RestMethod 'http://localhost:58080/dsh/readiness'",
        "Invoke-RestMethod 'http://localhost:58080/dsh/stores?limit=10&offset=0'",
        "Invoke-RestMethod 'http://localhost:58080/dsh/home-discovery'"
      ],
      "required_before": "SLICE_CLOSURE",
      "checks": [
        "All endpoints return HTTP 200",
        "Response body contains expected schema fields",
        "Data comes from seeded DB (not mock)"
      ],
      "current_status": "PASS"
    },
    "WLT_BOUNDARY_GATE": {
      "id": "WLT_BOUNDARY_GATE",
      "name": "WLT Financial Boundary Gate",
      "command": "pnpm run guard:no-financial-mutation-outside-wlt",
      "script": "tools/guards/no-financial-mutation-outside-wlt.mjs",
      "required_before": "ANY_DSH_SLICE",
      "checks": [
        "Zero financial mutations outside services/wlt/",
        "DSH only holds: paymentSessionId, paymentStatus, financialReference, settlementStatus (read-only)",
        "No wallet/payment/refund/settlement/ledger/payout/commission/COD/reconciliation in DSH",
        "WLT is CONTRACT_ONLY until dedicated WLT slice activates"
      ],
      "current_status": "PASS"
    },
    "UI_KIT_GATE": {
      "id": "UI_KIT_GATE",
      "name": "UI Kit Compliance Gate",
      "command": "pnpm run guard:no-direct-fetch-in-screen",
      "script": "tools/guards/no-direct-fetch-in-screen.mjs",
      "required_before": "FRONTEND_CLOSURE",
      "checks": [
        "No Tamagui imports directly in app screens (must go through shared/ui-kit)",
        "No local design system (no local components duplicating ui-kit)",
        "No direct fetch() in screen components (must use typed client)",
        "All UI components use BthwaniUiProvider"
      ],
      "current_status": "PASS"
    },
    "VISUAL_EVIDENCE_GATE": {
      "id": "VISUAL_EVIDENCE_GATE",
      "name": "Visual Evidence Gate",
      "required_before": "SLICE_CLOSURE",
      "checks": [
        "Screenshot or screen recording saved under services/dsh/evidence/{SLICE_ID}/",
        "Screenshot shows real data (not empty state or error screen)",
        "All affected surfaces have visual evidence",
        "Evidence file referenced in slice evidence manifest"
      ],
      "current_status": "PER_SLICE",
      "note": "Cannot be automated. Must be manually captured and stored."
    },
    "NO_OLD_PORTS_GATE": {
      "id": "NO_OLD_PORTS_GATE",
      "name": "No Old Ports Gate",
      "command": "Select-String -Path 'C:\\bthwani-suite-next\\**\\*' -Pattern ':(8080|8081|8082|8083|8084|3000)' -Recurse -ErrorAction SilentlyContinue | Where-Object { $_.Path -notmatch 'node_modules|.next|machine-readable' }",
      "required_before": "ANY_SLICE",
      "forbidden_ports": [8080, 8081, 8082, 8083, 8084, 3000],
      "exception": "container_port 8080 is allowed inside compose.runtime.yml ONLY (mapped to host 58080). Port 8080 must NOT appear as a host port.",
      "current_status": "PASS"
    },
    "NO_MOCK_DEMO_GATE": {
      "id": "NO_MOCK_DEMO_GATE",
      "name": "No Mock/Demo/Preview Runtime Gate",
      "command": "pnpm run guard:no-preview-demo-mock-runtime",
      "script": "tools/guards/no-preview-demo-mock-runtime.mjs",
      "required_before": "RUNTIME_VERIFICATION",
      "checks": [
        "No preview runtime data",
        "No demo runtime data",
        "No mock runtime data in production paths",
        "No fake actor IDs in runtime code"
      ],
      "current_status": "PASS"
    }
  },
  "gate_sequence": [
    "FOUNDATION_GATE",
    "CONTRACTS_LINT_GATE",
    "GUARD_MATRIX_V3",
    "WLT_BOUNDARY_GATE",
    "NO_OLD_PORTS_GATE",
    "NO_MOCK_DEMO_GATE",
    "DOCKER_RUNTIME_GATE",
    "DSH_API_GATE",
    "DSH_SLICE_GATE",
    "UI_KIT_GATE",
    "VISUAL_EVIDENCE_GATE"
  ],
  "pre_slice_required": [
    "FOUNDATION_GATE",
    "CONTRACTS_LINT_GATE",
    "GUARD_MATRIX_V3",
    "WLT_BOUNDARY_GATE",
    "NO_OLD_PORTS_GATE",
    "NO_MOCK_DEMO_GATE"
  ],
  "per_slice_required": [
    "DOCKER_RUNTIME_GATE",
    "DSH_API_GATE",
    "DSH_SLICE_GATE",
    "UI_KIT_GATE",
    "VISUAL_EVIDENCE_GATE"
  ]
}
