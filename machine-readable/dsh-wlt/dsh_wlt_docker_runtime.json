{
  "$schema": "dsh-wlt-docker-runtime/v1",
  "_meta": {
    "description": "Docker runtime specification for DSH/WLT. Single compose file policy. No per-slice compose files.",
    "compose_file": "infra/docker/compose.runtime.yml",
    "runtime_script": "infra/docker/scripts/runtime.ps1",
    "last_verified": "2026-06-21"
  },
  "policy": {
    "single_compose_file": true,
    "forbidden_compose_files": [
      "compose.local.yml",
      "compose.full.yml",
      "compose.slice.yml",
      "docker-compose.yml",
      "docker-compose.local.yml"
    ],
    "profiles_required": true
  },
  "services": {
    "postgres": {
      "image": "postgres:16-alpine",
      "host_port": 55432,
      "container_port": 5432,
      "profile": "always-on",
      "env": {
        "POSTGRES_DB": "bthwani_local",
        "POSTGRES_USER": "bthwani",
        "POSTGRES_PASSWORD": "bthwani_local"
      },
      "health_check": "pg_isready -U bthwani -d bthwani_local",
      "status": "CONFIGURED"
    },
    "minio": {
      "image": "minio/minio:latest",
      "host_port_api": 59000,
      "host_port_console": 59001,
      "container_port_api": 9000,
      "container_port_console": 9001,
      "profile": "media",
      "command": "server /data --console-address ':9001'",
      "status": "CONFIGURED"
    },
    "dsh-api": {
      "build_context": "services/dsh/backend",
      "dockerfile": "services/dsh/backend/Dockerfile",
      "host_port": 58080,
      "container_port": 8080,
      "profile": "dsh",
      "depends_on": ["postgres"],
      "env": {
        "DSH_DB_HOST": "postgres",
        "DSH_DB_PORT": "5432",
        "DSH_DB_NAME": "bthwani_local",
        "DSH_DB_USER": "bthwani",
        "DSH_DB_PASSWORD": "bthwani_local",
        "DSH_DB_SSLMODE": "disable"
      },
      "status": "CONFIGURED"
    }
  },
  "lifecycle_actions": {
    "migrate": {
      "type": "powershell-script",
      "command": "infra/docker/scripts/runtime.ps1 -Action migrate",
      "pnpm_alias": "pnpm runtime:migrate",
      "runs_sql_from": "services/dsh/database/migrations/",
      "not_a_compose_service": true
    },
    "seed": {
      "type": "powershell-script",
      "command": "infra/docker/scripts/runtime.ps1 -Action seed",
      "pnpm_alias": "pnpm runtime:seed",
      "runs_sql_from": "services/dsh/database/seeds/local/",
      "not_a_compose_service": true,
      "note": "Seeds only run in local dev. Never in staging/production."
    },
    "smoke": {
      "type": "powershell-script",
      "command": "infra/docker/scripts/runtime.ps1 -Action smoke",
      "pnpm_alias": "pnpm runtime:smoke",
      "not_a_compose_service": true
    },
    "all": {
      "command": "infra/docker/scripts/runtime.ps1 -Action all",
      "pnpm_alias": "pnpm runtime:all",
      "sequence": ["up", "migrate", "seed", "smoke"]
    },
    "status": {
      "command": "infra/docker/scripts/runtime.ps1 -Action status",
      "pnpm_alias": "pnpm runtime:status"
    }
  },
  "smoke_endpoints": [
    {
      "name": "DSH Health",
      "method": "GET",
      "url": "http://localhost:58080/dsh/health",
      "expected_status": 200,
      "expected_body_contains": "ok",
      "powershell": "Invoke-RestMethod 'http://localhost:58080/dsh/health'"
    },
    {
      "name": "DSH Readiness",
      "method": "GET",
      "url": "http://localhost:58080/dsh/readiness",
      "expected_status": 200,
      "powershell": "Invoke-RestMethod 'http://localhost:58080/dsh/readiness'"
    },
    {
      "name": "DSH Stores List",
      "method": "GET",
      "url": "http://localhost:58080/dsh/stores?limit=10&offset=0",
      "expected_status": 200,
      "expected_body_contains": "stores",
      "powershell": "Invoke-RestMethod 'http://localhost:58080/dsh/stores?limit=10&offset=0'"
    },
    {
      "name": "DSH Home Discovery",
      "method": "GET",
      "url": "http://localhost:58080/dsh/home-discovery",
      "expected_status": 200,
      "powershell": "Invoke-RestMethod 'http://localhost:58080/dsh/home-discovery'"
    }
  ],
  "startup_commands": {
    "step_1_start_docker": "docker compose -f infra/docker/compose.runtime.yml --profile dsh --profile media up -d",
    "step_2_migrate": "infra/docker/scripts/runtime.ps1 -Action migrate",
    "step_3_seed": "infra/docker/scripts/runtime.ps1 -Action seed",
    "step_4_smoke": "infra/docker/scripts/runtime.ps1 -Action smoke",
    "all_in_one": "pnpm runtime:all"
  },
  "wlt_docker_status": {
    "state": "NOT_CONFIGURED",
    "reason": "WLT is CONTRACT_ONLY. No WLT compose service until WLT slice is approved and runtime-verified.",
    "activation_condition": "WLT-FOUNDATION slice gates PASS + dedicated WLT implementation slice approved"
  }
}
