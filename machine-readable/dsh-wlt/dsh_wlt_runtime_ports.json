{
  "$schema": "dsh-wlt-runtime-ports/v1",
  "_meta": {
    "description": "Canonical port registry for DSH/WLT runtime. These are the ONLY ports allowed. No old ports (8080-8084, 3000) are permitted anywhere in the codebase.",
    "enforced_by": "tools/guards/docker-runtime-profiles.mjs",
    "last_verified": "2026-06-21",
    "target_branch": "starting-implementing-slices"
  },
  "canonical_ports": {
    "DSH_API": {
      "host_port": 58080,
      "container_port": 8080,
      "env_var": "BTHWANI_DSH_API_HOST_PORT",
      "expose_env": "EXPO_PUBLIC_DSH_API_BASE_URL",
      "expose_next": "NEXT_PUBLIC_DSH_API_BASE_URL",
      "service": "dsh-api",
      "profile": "dsh",
      "smoke_endpoint": "http://localhost:58080/dsh/health"
    },
    "POSTGRES": {
      "host_port": 55432,
      "container_port": 5432,
      "env_var": "BTHWANI_POSTGRES_PORT",
      "service": "postgres",
      "profile": "always-on"
    },
    "MINIO_API": {
      "host_port": 59000,
      "container_port": 9000,
      "env_var": "BTHWANI_MINIO_API_PORT",
      "service": "minio",
      "profile": "media"
    },
    "MINIO_CONSOLE": {
      "host_port": 59001,
      "container_port": 9001,
      "env_var": "BTHWANI_MINIO_CONSOLE_PORT",
      "service": "minio",
      "profile": "media"
    },
    "APP_CLIENT": {
      "host_port": 18101,
      "type": "expo-dev-server",
      "env_var": "EXPO_PORT",
      "surface": "app-client",
      "start_command": "pnpm --dir apps/app-client/runtime exec expo start --dev-client --host localhost --port 18101 --android --clear"
    },
    "APP_PARTNER": {
      "host_port": 18102,
      "type": "expo-dev-server",
      "env_var": "EXPO_PORT",
      "surface": "app-partner",
      "start_command": "pnpm --dir apps/app-partner/runtime exec expo start --dev-client --host localhost --port 18102 --android --clear"
    },
    "APP_CAPTAIN": {
      "host_port": 18103,
      "type": "expo-dev-server",
      "env_var": "EXPO_PORT",
      "surface": "app-captain",
      "start_command": "pnpm --dir apps/app-captain/runtime exec expo start --dev-client --host localhost --port 18103 --android --clear"
    },
    "APP_FIELD": {
      "host_port": 18104,
      "type": "expo-dev-server",
      "env_var": "EXPO_PORT",
      "surface": "app-field",
      "start_command": "pnpm --dir apps/app-field/runtime exec expo start --dev-client --host localhost --port 18104 --android --clear"
    },
    "CONTROL_PANEL": {
      "host_port": 13000,
      "type": "next-dev-server",
      "env_var": "PORT",
      "surface": "control-panel",
      "start_command": "pnpm --dir apps/control-panel/runtime dev --port 13000"
    }
  },
  "forbidden_ports": [8080, 8081, 8082, 8083, 8084, 3000],
  "forbidden_reason": "Old monolith ports from donor repo (C:\\bthwani-suite). Must never appear in target (C:\\bthwani-suite-next).",
  "adb_reverse_required": [
    { "device_port": 58080, "host_port": 58080, "service": "DSH_API" }
  ],
  "adb_reverse_command": "$Adb = \"$env:LOCALAPPDATA\\Android\\Sdk\\platform-tools\\adb.exe\"; & $Adb reverse tcp:58080 tcp:58080"
}
