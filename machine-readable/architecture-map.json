{
  "schema_version": "1.0.0",
  "last_updated": "2026-06-22",

  "services": {
    "dsh": {
      "role": "ACTIVE_IMPLEMENTATION_TARGET",
      "description": "Discovery + Store + Home — operational commerce layer",
      "status": "DSH-001_RUNTIME_VERIFIED_DSH-002_PARTIAL",
      "backend": {
        "language": "Go",
        "path": "services/dsh/backend/",
        "dockerfile": "services/dsh/backend/Dockerfile",
        "handlers_implemented": ["health", "readiness", "store-list", "store-get", "home-discovery"],
        "internal_port": 8080,
        "host_port": 58080
      },
      "contract": {
        "path": "services/dsh/contracts/dsh.openapi.yaml",
        "version": "0.3.0",
        "state": "CONTRACT_ACTIVE",
        "operations": ["getDshHealth", "getDshReadiness", "listDshStores", "getDshStore", "getDshHomeDiscovery"]
      },
      "database": {
        "path": "services/dsh/database/",
        "migrations_applied": ["dsh-001_store_discovery.sql", "dsh-002_home_discovery.sql"],
        "tables": ["dsh_stores", "dsh_home_banners", "dsh_home_promos", "dsh_categories"],
        "seeds_path": "services/dsh/database/seeds/local/"
      },
      "clients": {
        "path": "services/dsh/clients/",
        "generated": true,
        "files": ["store-discovery-client.ts", "home-discovery-client.ts"]
      },
      "frontend_shared_brain": "services/dsh/frontend/shared/",
      "frontend_surfaces": {
        "app-client": "services/dsh/frontend/app-client/",
        "app-partner": "services/dsh/frontend/app-partner/",
        "app-captain": "services/dsh/frontend/app-captain/",
        "app-field": "services/dsh/frontend/app-field/",
        "control-panel": "services/dsh/frontend/control-panel/"
      },
      "capabilities_path": "services/dsh/capabilities/",
      "service_manifest": "services/dsh/service.manifest.ts",
      "blueprint": "services/dsh/SERVICE_BLUEPRINT.md",
      "tests_path": "services/dsh/tests/",
      "evidence_path": "services/dsh/evidence/",
      "ownsFinancialTruth": false
    },
    "wlt": {
      "role": "FINANCIAL_BOUNDARY_OWNER",
      "description": "Wallet + Ledger + Finance — financial truth layer",
      "status": "WLT-000_FOUNDATION_RUNTIME_VERIFIED",
      "backend": {
        "language": "Go",
        "path": "services/wlt/backend/",
        "dockerfile": "services/wlt/backend/Dockerfile",
        "handlers_implemented": ["health", "readiness", "reference-endpoints"],
        "internal_port": 8083,
        "host_port": 58083,
        "mode": "public-read-references"
      },
      "contract": {
        "path": "services/wlt/contracts/wlt.openapi.yaml",
        "version": "0.2.0",
        "state": "CONTRACT_ACTIVE",
        "note": "Read-only reference endpoints only. No mutation APIs."
      },
      "database": {
        "path": "services/wlt/database/",
        "migrations_applied": ["wlt-000_financial_references.sql"],
        "tables": [
          "wlt_payment_status_refs",
          "wlt_settlement_status_refs",
          "wlt_refund_status_refs",
          "wlt_wallet_refs"
        ],
        "seeds_path": "services/wlt/database/seeds/"
      },
      "clients": {
        "path": "services/wlt/clients/",
        "generated": false,
        "note": "Client generation not yet done — WLT-001+ implementation slice required"
      },
      "frontend_shared_brain_for_dsh": "services/wlt/frontend/dsh/shared/",
      "frontend_surfaces": {
        "app-client": "services/wlt/frontend/app-client/ (gitkeep)",
        "app-partner": "services/wlt/frontend/app-partner/ (gitkeep)",
        "app-captain": "services/wlt/frontend/app-captain/ (gitkeep)",
        "app-field": "services/wlt/frontend/app-field/ (gitkeep)",
        "control-panel": "services/wlt/frontend/control-panel/ (skeleton proof only)"
      },
      "service_manifest": "services/wlt/service.manifest.ts",
      "blueprint": "services/wlt/SERVICE_BLUEPRINT.md",
      "evidence_path": "services/wlt/evidence/",
      "ownsFinancialTruth": true,
      "activation_note": "WLT-000 Foundation is RUNTIME_VERIFIED. WLT-001+ mutation slices require separate approval."
    },
    "stub_services": {
      "description": "These services have package.json scaffolding but no implementation yet.",
      "services": ["amn", "arb", "esf", "knz", "kwd", "mrf", "snd"],
      "status": "OUT_OF_SCOPE — not part of current slices"
    }
  },

  "apps": {
    "control-panel": {
      "type": "Next.js 16 web dashboard",
      "path": "apps/control-panel/runtime/",
      "role": "ROUTING_AND_SHELL_ONLY",
      "port": 13000,
      "env_var": "NEXT_PUBLIC_DSH_API_BASE_URL",
      "shell_source": "shared/app-shell/src/control-panel/",
      "archetypes_source": "shared/app-shell/src/control-panel/archetypes/",
      "forbidden": [
        "business logic",
        "direct fetch in pages",
        "service-specific screens",
        "local design system",
        "financial mutation"
      ],
      "start_command": "$env:NEXT_PUBLIC_DSH_API_BASE_URL='http://localhost:58080'; pnpm --dir apps/control-panel/runtime dev --port 13000"
    },
    "app-client": {
      "type": "Expo React Native (customer)",
      "path": "apps/app-client/runtime/",
      "port": 18101,
      "env_var": "EXPO_PUBLIC_DSH_API_BASE_URL"
    },
    "app-partner": {
      "type": "Expo React Native (merchant)",
      "path": "apps/app-partner/runtime/",
      "port": 18102,
      "env_var": "EXPO_PUBLIC_DSH_API_BASE_URL"
    },
    "app-captain": {
      "type": "Expo React Native (delivery captain)",
      "path": "apps/app-captain/runtime/",
      "port": 18103,
      "env_var": "EXPO_PUBLIC_DSH_API_BASE_URL"
    },
    "app-field": {
      "type": "Expo React Native (field agent)",
      "path": "apps/app-field/runtime/",
      "port": 18104,
      "env_var": "EXPO_PUBLIC_DSH_API_BASE_URL"
    },
    "webapp": {
      "type": "Web app scaffold",
      "path": "apps/webapp/runtime/",
      "status": "SCAFFOLD_ONLY"
    },
    "website": {
      "type": "Website scaffold",
      "path": "apps/website/runtime/",
      "status": "SCAFFOLD_ONLY"
    }
  },

  "packages": {
    "shared_ui_kit": {
      "path": "shared/ui-kit/",
      "role": "VISUAL_PRIMITIVES_OWNER",
      "owns": ["Tamagui configuration", "design tokens", "color roles", "typography", "spacing", "reusable UI components"],
      "forbidden": ["business logic", "API calls", "service-specific screens", "financial mutation"],
      "typecheck_command": "pnpm --dir shared/ui-kit typecheck",
      "status": "RUNTIME_VERIFIED"
    },
    "shared_app_shell": {
      "path": "shared/app-shell/",
      "role": "SHELL_AND_CONTRACTS",
      "owns": [
        "ControlPanelShell",
        "ControlPanelNavigation",
        "ControlPanelTopBar",
        "ControlPanelServiceContext",
        "ControlPanelSectionRegistry",
        "ControlPanelServiceRegistry",
        "section archetype frames"
      ],
      "forbidden": ["service business logic", "API clients", "direct fetch", "financial mutation", "Tamagui"],
      "archetypes": [
        "OverviewPageFrame", "DataTablePageFrame", "QueuePageFrame",
        "OperationsRoomFrame", "DetailPageFrame", "EditorPageFrame",
        "ReviewPageFrame", "MetricsPageFrame", "SettingsPageFrame", "FinanceReadOnlyFrame"
      ],
      "typecheck_command": "pnpm --dir shared/app-shell typecheck",
      "status": "RUNTIME_VERIFIED"
    },
    "shared_config": {
      "path": "shared/config/",
      "role": "TOOLCHAIN_LOCK",
      "files": ["toolchain-lock.json"]
    },
    "shared_testing": {
      "path": "shared/testing/",
      "role": "TEST_UTILITIES"
    }
  },

  "control_panel_sections": {
    "dashboard": {
      "archetypes": ["OverviewPageFrame", "MetricsPageFrame"],
      "dsh_slices": ["DSH-010 (finance visibility summary)"]
    },
    "operations": {
      "archetypes": ["OperationsRoomFrame", "QueuePageFrame", "DetailPageFrame"],
      "dsh_slices": ["DSH-007 (captain dispatch)", "DSH-007 (live orders)", "DSH-009 (interventions)"]
    },
    "finance": {
      "archetypes": ["FinanceReadOnlyFrame", "MetricsPageFrame"],
      "dsh_slices": ["DSH-010 (finance visibility)"],
      "constraint": "READ-ONLY — WLT boundary. No payment mutation."
    },
    "catalogs": {
      "archetypes": ["DataTablePageFrame", "EditorPageFrame", "ReviewPageFrame"],
      "dsh_slices": ["DSH-003 (catalog management)"]
    },
    "partners": {
      "archetypes": ["QueuePageFrame", "DetailPageFrame", "ReviewPageFrame"],
      "dsh_slices": ["DSH-001 (stores admin)", "DSH-008 (field readiness)", "DSH-006 (partner orders)"],
      "implemented_routes": ["/dsh/partners/stores"]
    },
    "marketing": {
      "archetypes": ["OverviewPageFrame", "EditorPageFrame", "MetricsPageFrame"],
      "dsh_slices": ["DSH-002 (home discovery admin — banners, promos, categories)"]
    },
    "support": {
      "archetypes": ["QueuePageFrame", "DetailPageFrame"],
      "dsh_slices": ["DSH-009 (support queue, case detail)"]
    },
    "platform": {
      "archetypes": ["SettingsPageFrame"],
      "dsh_slices": []
    },
    "administration": {
      "archetypes": ["DataTablePageFrame", "SettingsPageFrame"],
      "dsh_slices": []
    },
    "hr": {
      "archetypes": ["DataTablePageFrame", "QueuePageFrame"],
      "dsh_slices": []
    }
  },

  "docker_runtime": {
    "compose_file": "infra/docker/compose.runtime.yml",
    "policy": "Single compose file. No per-slice compose. No compose.local, compose.full, compose.slice.",
    "profiles": {
      "postgres": "always active",
      "dsh": "dsh-api service",
      "wlt": "wlt-api service",
      "media": "minio service"
    },
    "services": {
      "postgres": {"container": "bthwani-postgres-runtime", "port": "55432:5432"},
      "dsh-api": {"container": "bthwani-dsh-api-runtime", "port": "58080:8080", "profile": "dsh"},
      "wlt-api": {"container": "bthwani-wlt-api-runtime", "port": "58083:8083", "profile": "wlt"},
      "minio": {"container": "bthwani-minio-runtime", "ports": ["59000:9000", "59001:9001"], "profile": "media"}
    },
    "runtime_verified": true,
    "runtime_status_command": "pnpm runtime:status"
  },

  "toolchain": {
    "node": ">=24.17.0 <25",
    "pnpm": "10.34.2",
    "typescript": "~6.0.3",
    "lock_file": "shared/config/toolchain-lock.json",
    "governance_doc": "governance/10_TOOLCHAIN_VERSION_LOCK.md",
    "rule": "Both files must be updated in the same commit when toolchain changes."
  },

  "canonical_ports": {
    "POSTGRES": 55432,
    "DSH_API": 58080,
    "WLT_API": 58083,
    "MINIO_API": 59000,
    "MINIO_CONSOLE": 59001,
    "APP_CLIENT": 18101,
    "APP_PARTNER": 18102,
    "APP_CAPTAIN": 18103,
    "APP_FIELD": 18104,
    "CONTROL_PANEL": 13000
  },

  "forbidden_ports_as_host": [8080, 8081, 8082, 8083, 8084, 3000]
}
