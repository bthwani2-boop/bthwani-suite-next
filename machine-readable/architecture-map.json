  "dsh_order_state_machine": {
    "owner": "dsh",
    "principle": "DSH owns order operational state lifecycle. WLT is triggered only at payment-relevant transitions. DSH must not own financial truth.",
    "db_table": "orders",
    "db_columns": ["state", "valid_from", "valid_to", "transition_log"],
    "idempotency_key": "order_id + correlation_id",
    "event_on_every_transition": "order.state.changed",
    "states": [
      "pending",
      "store-accepted",
      "preparing",
      "ready-for-pickup",
      "dispatching",
      "driver-assigned",
      "driver-arrived-store",
      "picked-up",
      "arrived-customer",
      "delivered",
      "cancelled-by-client",
      "cancelled-by-store",
      "cancelled-no-driver",
      "failed-payment",
      "failed-dispatch"
    ],
    "error_cases": ["invalid_transition", "duplicate_transition", "auth_failure"],
    "rollback_rule": "invalid transition -> no state mutation; audited rejection logged",
    "wlt_trigger_policy": "WLT triggered only at payment-relevant transitions (payment initiation, COD collection at delivery, refund after cancellation). Order state itself is DSH-authoritative.",
    "required_for_topic": "DSH-006 (Order Fulfillment), DSH-007 (Dispatch & Delivery)",
    "note": "State machine diagram required before DSH-006 implementation. BLOCKED_NEEDS_DOMAIN_MODEL until spec approved."
  },

  "dsh_dispatch_policy": {
    "owner": "dsh",
    "principle": "DSH owns dispatch logic. WLT owns payment authorization before dispatch. Captain assignment is DSH-operational.",
    "db_tables": ["dispatch_attempts", "captain_assignments", "zone_config"],
    "idempotency_key": "order_id + attempt_sequence",
    "state_trigger": "pending -> dispatching -> driver-assigned",
    "audit_rule": "audit actor_id actor_role object_id action from_state to_state correlation_id timestamp",
    "rollback_rule": "dispatch failure -> release WLT payment authorization; requeue order",
    "policies": [
      {
        "policy_id": "dispatch-radial-search",
        "rule": "Search drivers within configurable radius; expand radius if no match within timeout window"
      },
      {
        "policy_id": "dispatch-priority-routing",
        "rule": "Priority order: online captain -> nearest -> highest rating -> manual operator escalation"
      },
      {
        "policy_id": "dispatch-auto-reject",
        "rule": "Auto-reject dispatch offer if captain does not accept within configurable time window"
      },
      {
        "policy_id": "dispatch-batching",
        "rule": "Batch orders to same captain if same zone and within batch time window"
      },
      {
        "policy_id": "dispatch-manual-escalation",
        "rule": "Operator can manually assign captain from control-panel operations room if auto-dispatch fails"
      },
      {
        "policy_id": "dispatch-geofencing",
        "rule": "Enforce active zone polygon; check zone version; store radius; reject if zone inactive or stale"
      },
      {
        "policy_id": "dispatch-partner-blacklist",
        "rule": "Do not dispatch to blocked or suspended partners; check partner status before dispatch assignment"
      }
    ],
    "required_for_topic": "DSH-007 (Dispatch & Captain Delivery Lifecycle)",
    "note": "Full dispatch policy spec required before DSH-007 execution."
  },

  "pricing_policy_summary": {
    "owner": "wlt",
    "principle": "All financial calculations belong to WLT. DSH sends order details to WLT which returns a payment session reference. DSH never calculates amounts.",
    "policies": [
      {
        "policy_id": "base-delivery-fee",
        "rule": "Calculated by WLT per zone and distance tier at checkout intent; DSH sends store_id + customer_location + items"
      },
      {
        "policy_id": "surge-pricing",
        "rule": "WLT applies surge multiplier during peak demand/supply ratio; DSH displays paymentStatus reference only"
      },
      {
        "policy_id": "service-fee",
        "rule": "Platform commission percentage per order; calculated and owned by WLT"
      },
      {
        "policy_id": "discount-application",
        "rule": "Promo codes and loyalty discounts applied by WLT at checkout; DSH sends promo_code reference to WLT"
      },
      {
        "policy_id": "vat-calculation",
        "rule": "Tax calculation per jurisdiction; WLT-owned; DSH receives tax_included amount only as display reference"
      }
    ],
    "dsh_forbidden": "DSH must not compute, store, or mutate any price or amount. All pricing is WLT-owned.",
    "required_for_topic": "DSH-005 (Checkout Intent & WLT Handoff)"
  },

  "cod_policy_summary": {
    "owner": "wlt",
    "principle": "Cash-on-delivery collection and reconciliation are WLT financial operations. DSH captain marks delivery; WLT handles COD financial state.",
    "policies": [
      {
        "policy_id": "cod-collection-at-delivery",
        "rule": "Captain collects exact amount displayed on order at delivery; amount sourced from WLT payment session reference"
      },
      {
        "policy_id": "cod-amount-verification",
        "rule": "Order total must match WLT-expected amount before physical handover; mismatch triggers support escalation"
      },
      {
        "policy_id": "cod-remittance",
        "rule": "Captain transfers collected cash to designated settlement point; WLT records COD_financial_state transition"
      },
      {
        "policy_id": "cod-reconciliation",
        "rule": "Daily COD reconciliation between captain cash and WLT settlement records; owned entirely by WLT"
      },
      {
        "policy_id": "cod-failure-escalation",
        "rule": "COD collection failure triggers WLT refund flow if payment was pre-authorized; DSH order state = failed-payment"
      }
    ],
    "dsh_forbidden": "DSH must not own COD financial state. DSH may display COD payment status reference from WLT only.",
    "required_for_topic": "DSH-007 (Dispatch & Delivery) for captain side; WLT-001+ for financial state"
  },

  "notification_triggers_summary": {
    "owner": "dsh (operational notifications); wlt (financial notifications)",
    "principle": "Every order and financial state transition must emit a typed event with correlation_id. Notification service consumes events.",
    "triggers": [
      {"event": "order.state.pending", "notify": ["partner"], "message": "New order incoming — accept or reject"},
      {"event": "order.state.store-accepted", "notify": ["client"], "message": "Your order has been accepted by the store"},
      {"event": "order.state.preparing", "notify": ["client"], "message": "Your order is being prepared"},
      {"event": "order.state.ready-for-pickup", "notify": ["captain"], "message": "Order ready for pickup — navigate to store"},
      {"event": "order.state.driver-assigned", "notify": ["client"], "message": "Captain assigned; tracking available"},
      {"event": "order.state.dispatching", "notify": ["client"], "message": "Captain is on the way to the store"},
      {"event": "order.state.driver-arrived-store", "notify": ["partner"], "message": "Captain has arrived at store"},
      {"event": "order.state.picked-up", "notify": ["client"], "message": "Order picked up; captain is on the way"},
      {"event": "order.state.arrived-customer", "notify": ["client"], "message": "Captain has arrived — please receive your order"},
      {"event": "order.state.delivered", "notify": ["client", "partner"], "message": "Order delivered successfully"},
      {"event": "order.state.cancelled-by-client", "notify": ["partner", "captain"], "message": "Order cancelled by client"},
      {"event": "order.state.cancelled-by-store", "notify": ["client", "captain"], "message": "Order cancelled by store"},
      {"event": "order.state.cancelled-no-driver", "notify": ["client", "partner", "operator"], "message": "No captain available — order cancelled"},
      {"event": "order.state.failed-dispatch", "notify": ["operator"], "message": "Manual intervention required — dispatch failed"},
      {"event": "order.state.failed-payment", "notify": ["client"], "message": "Payment failed — order cancelled"},
      {"event": "wlt.financial.state.captured", "notify": ["partner"], "message": "Payment captured — proceed with order"},
      {"event": "wlt.financial.state.settled", "notify": ["partner"], "message": "Settlement completed"},
      {"event": "wlt.financial.state.refund-completed", "notify": ["client"], "message": "Refund processed successfully"},
      {"event": "store.onboarding.submitted", "notify": ["field_team", "operator"], "message": "Store onboarding documents submitted for review"},
      {"event": "store.onboarding.approved", "notify": ["partner"], "message": "Your store has been approved"},
      {"event": "store.onboarding.rejected", "notify": ["partner"], "message": "Store onboarding rejected — reason attached"},
      {"event": "support.case.escalated", "notify": ["operator"], "message": "Support case escalated — requires intervention"},
      {"event": "captain.assigned.new-task", "notify": ["captain"], "message": "New delivery assignment — tap to view"}
    ],
    "required_for_topic": "DSH-011 (Notifications & Actor Communication)"
  },

