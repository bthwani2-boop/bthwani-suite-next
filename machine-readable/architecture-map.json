  "apps": {
    "control-panel": {
      "type": "Next.js 16 web dashboard",
      "path": "apps/control-panel/runtime/",
      "role": "ROUTING_AND_SHELL_ONLY",
      "port": 13000,
      "env_var": "NEXT_PUBLIC_DSH_API_BASE_URL",
      "shell_source": "shared/app-shell/src/control-panel/",
      "archetypes_source": "shared/app-shell/src/control-panel/archetypes/",
      "forbidden": [
        "business logic",
        "direct fetch in pages",
        "service-specific screens (use service ui paths)",
        "local design system",
        "financial mutation",
        "Tamagui imports"
      ],
      "start_command": "$env:NEXT_PUBLIC_DSH_API_BASE_URL='http://localhost:58080'; pnpm --dir apps/control-panel/runtime dev --port 13000"
    },
    "app-client": {
      "type": "Expo React Native (customer)",
      "path": "apps/app-client/runtime/",
      "port": 18101,
      "env_var": "EXPO_PUBLIC_DSH_API_BASE_URL",
      "start_command": "$env:EXPO_PUBLIC_DSH_API_BASE_URL='http://127.0.0.1:58080'; pnpm --dir apps/app-client/runtime exec expo start --dev-client --host localhost --port 18101 --android --clear"
    },
    "app-partner": {
      "type": "Expo React Native (merchant)",
      "path": "apps/app-partner/runtime/",
      "port": 18102,
      "env_var": "EXPO_PUBLIC_DSH_API_BASE_URL",
      "start_command": "$env:EXPO_PUBLIC_DSH_API_BASE_URL='http://127.0.0.1:58080'; pnpm --dir apps/app-partner/runtime exec expo start --dev-client --host localhost --port 18102 --android --clear"
    },
    "app-captain": {
      "type": "Expo React Native (delivery captain)",
      "path": "apps/app-captain/runtime/",
      "port": 18103,
      "env_var": "EXPO_PUBLIC_DSH_API_BASE_URL"
    },
    "app-field": {
      "type": "Expo React Native (field agent)",
      "path": "apps/app-field/runtime/",
      "port": 18104,
      "env_var": "EXPO_PUBLIC_DSH_API_BASE_URL"
    },
    "webapp": {
      "type": "Web app scaffold",
      "path": "apps/webapp/runtime/",
      "status": "SCAFFOLD_ONLY"
    },
    "website": {
      "type": "Website scaffold",
      "path": "apps/website/runtime/",
      "status": "SCAFFOLD_ONLY"
    }
